  .subsidy-inner { grid-template-columns: 1fr 1fr; gap: 72px; }
  .subsidy-content-col { padding-top: 0; }
  .subsidy-photo { height: 420px; }
  .accordion-q { font-size: 1rem; }
}
</style>

<script>
  // ===== ACCORDION =====
  document.querySelectorAll<HTMLElement>('.accordion-trigger').forEach(trigger => {
    trigger.addEventListener('click', () => {
      const item   = trigger.closest<HTMLElement>('.accordion-item')!;
      const panel  = item.querySelector<HTMLElement>('.accordion-panel')!;
      const isOpen = item.classList.contains('is-open');

      // Close siblings
      item.closest<HTMLElement>('.accordion')!
        .querySelectorAll<HTMLElement>('.accordion-item.is-open')
        .forEach(open => {
          if (open !== item) {
            open.classList.remove('is-open');
            open.querySelector<HTMLElement>('.accordion-panel')!.style.maxHeight = '0';
            open.querySelector<HTMLButtonElement>('.accordion-trigger')!.setAttribute('aria-expanded', 'false');
          }
        });

      if (isOpen) {
        item.classList.remove('is-open');
        panel.style.maxHeight = '0';
        trigger.setAttribute('aria-expanded', 'false');
      } else {
        item.classList.add('is-open');
        panel.style.maxHeight = panel.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });

  // ===== SEARCH =====
  const searchInput = document.getElementById('faq-search') as HTMLInputElement;
  const searchClear = document.getElementById('faq-search-clear') as HTMLButtonElement;
  const noResults   = document.getElementById('no-results') as HTMLElement;
  const searchHint  = document.getElementById('faq-search-hint') as HTMLElement;
  const allItems    = Array.from(document.querySelectorAll<HTMLElement>('.accordion-item'));
  const allCats     = Array.from(document.querySelectorAll<HTMLElement>('.faq-category'));

  function runSearch(q: string) {
    const term = q.toLowerCase().trim();
    searchClear.classList.toggle('visible', term.length > 0);

    if (!term) {
      allItems.forEach(i => i.classList.remove('accordion-item--hidden'));
      allCats.forEach(c => (c.style.display = ''));
      noResults.style.display = 'none';
      searchHint.textContent = '25 questions across 6 topics';
      return;
    }

    let visible = 0;
    allItems.forEach(item => {
      const q2 = item.dataset.question || '';
      const a  = item.querySelector('.accordion-panel__body p')?.textContent?.toLowerCase() || '';
      const ok = q2.includes(term) || a.includes(term);
      item.classList.toggle('accordion-item--hidden', !ok);
      if (ok) visible++;
    });

    allCats.forEach(cat => {
      cat.style.display = cat.querySelectorAll('.accordion-item:not(.accordion-item--hidden)').length > 0 ? '' : 'none';
    });

    noResults.style.display = visible === 0 ? 'flex' : 'none';
    searchHint.textContent  = visible > 0 ? `${visible} result${visible !== 1 ? 's' : ''} found` : 'No results';
  }

  searchInput.addEventListener('input', e => runSearch((e.target as HTMLInputElement).value));

  function clearSearch() { searchInput.value = ''; runSearch(''); searchInput.focus(); }
  searchClear.addEventListener('click', clearSearch);
  document.getElementById('clear-search-btn')?.addEventListener('click', clearSearch);

  // ===== CATEGORY PILLS =====
  const pills = Array.from(document.querySelectorAll<HTMLButtonElement>('.cat-pill'));

  pills.forEach(pill => {
    pill.addEventListener('click', () => {
      pills.forEach(p => p.classList.remove('cat-pill--active'));
      pill.classList.add('cat-pill--active');
      searchInput.value = '';
      runSearch('');

      const filter = pill.dataset.filter;
      allCats.forEach(cat => {
        cat.style.display = filter === 'all' || cat.dataset.category === filter ? '' : 'none';
      });

      if (filter !== 'all') {
        const target = document.getElementById(`cat-${filter}`);
        if (target) window.scrollTo({ top: target.getBoundingClientRect().top + window.scrollY - 160, behavior: 'smooth' });
      }
    });
  });

  // Auto-highlight active pill while scrolling
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => {
      if (e.isIntersecting) {
        const id = (e.target as HTMLElement).dataset.category;
        pills.forEach(p => p.classList.remove('cat-pill--active'));
        (pills.find(p => p.dataset.filter === id) || pills[0]).classList.add('cat-pill--active');
      }
    });
  }, { rootMargin: '-130px 0px -60% 0px' });
  allCats.forEach(c => io.observe(c));
</script>
