---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Contact Us — Rayenna Energy" description="Contact Rayenna Energy for a free solar consultation in Kochi, Kerala. Call, email or fill the form and we'll get back to you within 24 hours.">

  <!-- Page Hero -->
  <section class="page-hero">
    <div class="container" style="text-align:center; position:relative; z-index:1">
      <span class="section-tag">Get in Touch</span>
      <h1 class="page-hero__title">Let's <span>Connect!</span></h1>
      <p class="page-hero__subtitle">Ready to take the next step? Contact us today for a consultation and start your journey toward a more sustainable, cost-effective energy solution.</p>
    </div>
    <div class="page-hero__wave">
      <svg viewBox="0 0 1440 60" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,30 C360,60 1080,0 1440,30 L1440,60 L0,60 Z" fill="#f8f9fa"/>
      </svg>
    </div>
  </section>

  <!-- Contact Grid -->
  <section style="padding:var(--section-padding); background:var(--color-light)">
    <div class="container contact-grid">

      <!-- Info Column -->
      <div class="contact-info">
        <h2 class="section-title">We'd Love to <span>Hear From You</span></h2>
        <p style="color:var(--color-text-muted); line-height:1.8; margin-bottom:32px">Whether you have a question about our services, need a quote, or just want to learn more about solar — we're here to help.</p>

        <div class="contact-cards">
          <div class="contact-card">
            <div class="contact-card__icon">📍</div>
            <div>
              <strong>Visit Us</strong>
              <p>No. 3324/52, Ray Bhavan, NH Bypass, Thykoodam, Vyttila, Ernakulam, Kerala 682019</p>
            </div>
          </div>
          <div class="contact-card">
            <div class="contact-card__icon">📞</div>
            <div>
              <strong>Call Us</strong>
              <p><a href="tel:+919999999999">+91 99999 99999</a></p>
              <p style="font-size:0.85rem; color:var(--color-text-muted)">Mon – Sat, 9 AM – 6 PM</p>
            </div>
          </div>
          <div class="contact-card">
            <div class="contact-card__icon">✉️</div>
            <div>
              <strong>Email Us</strong>
              <p><a href="mailto:info@rayenna.energy">info@rayenna.energy</a></p>
              <p style="font-size:0.85rem; color:var(--color-text-muted)">We reply within 24 hours</p>
            </div>
          </div>
        </div>

        <!-- Map placeholder -->
        <div class="map-placeholder">
          <div class="map-pin">📍</div>
          <p>Vyttila, Kochi, Kerala</p>
          <a href="https://maps.google.com/?q=Vyttila,+Kochi,+Kerala" target="_blank" rel="noopener" class="map-link">
            Open in Google Maps →
          </a>
        </div>
      </div>

      <!-- Form Column -->
      <div class="contact-form-wrap" id="callback">
        <div class="form-header">
          <h3>Request a Free Consultation</h3>
          <p>Fill in your details and our solar expert will call you within 24 hours.</p>
        </div>
        <form class="contact-form" id="contact-form" novalidate>
          <div class="form-row">
            <div class="form-group">
              <label for="name">Full Name *</label>
              <input type="text" id="name" name="name" placeholder="Your full name" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number *</label>
              <input type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required />
            </div>
          </div>
          <div class="form-group">
            <label for="email">Email Address</label>
            <input type="email" id="email" name="email" placeholder="you@example.com" />
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="type">Property Type *</label>
              <select id="type" name="type" required>
                <option value="">Select type...</option>
                <option value="residential">Residential (Home/Villa)</option>
                <option value="commercial">Commercial (Business)</option>
                <option value="industrial">Industrial</option>
                <option value="other">Other</option>
              </select>
            </div>
            <div class="form-group">
              <label for="budget">Approximate Budget</label>
              <select id="budget" name="budget">
                <option value="">Select range...</option>
                <option value="under1l">Under ₹1 Lakh</option>
                <option value="1-3l">₹1–3 Lakhs</option>
                <option value="3-5l">₹3–5 Lakhs</option>
                <option value="above5l">Above ₹5 Lakhs</option>
              </select>
            </div>
          </div>
          <div class="form-group">
            <label for="message">Message / Questions</label>
            <textarea id="message" name="message" rows="4" placeholder="Tell us about your property, current electricity bill, or any questions you have..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary submit-btn">
            <span class="btn-text">Send My Request →</span>
            <span class="btn-loading" style="display:none">Sending...</span>
          </button>
          <p class="form-note">✓ Free consultation &nbsp;·&nbsp; ✓ No obligation &nbsp;·&nbsp; ✓ 24-hr response</p>
          <div class="form-success" id="form-success" style="display:none">
            <span>✅</span>
            <div>
              <strong>Thank you! We've received your request.</strong>
              <p>Our solar expert will call you within 24 hours.</p>
            </div>
          </div>
        </form>
      </div>

    </div>
  </section>

</Layout>

<style>
.page-hero {
  background: linear-gradient(135deg, #1e3a5f 0%, #2b5289 100%);
  padding: 140px 0 80px;
  position: relative;
}
.page-hero__title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 800;
  color: white;
  margin: 12px 0 20px;
}
.page-hero__title span { color: var(--color-primary); }
.page-hero__subtitle { color: rgba(255,255,255,0.8); max-width: 600px; margin: 0 auto; line-height: 1.8; }
.page-hero__wave { position: absolute; bottom: 0; left: 0; right: 0; line-height: 0; }
.page-hero__wave svg { width: 100%; display: block; }

.contact-grid {
  display: grid;
  grid-template-columns: 1fr 1.4fr;
  gap: 64px;
  align-items: start;
}

.contact-cards { display: flex; flex-direction: column; gap: 16px; margin-bottom: 32px; }
.contact-card {
  display: flex;
  gap: 16px;
  align-items: flex-start;
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 20px;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition);
}
.contact-card:hover { box-shadow: var(--shadow-md); transform: translateX(4px); }
.contact-card__icon { font-size: 1.6rem; flex-shrink: 0; }
.contact-card strong {
  display: block;
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-secondary);
  margin-bottom: 4px;
}
.contact-card p { color: var(--color-text-muted); font-size: 0.92rem; line-height: 1.5; }
.contact-card a { color: var(--color-primary); font-weight: 600; }

.map-placeholder {
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 40px 24px;
  text-align: center;
  box-shadow: var(--shadow-sm);
  border: 2px dashed var(--color-border);
}
.map-pin { font-size: 3rem; margin-bottom: 12px; }
.map-placeholder p { color: var(--color-text-muted); margin-bottom: 16px; }
.map-link {
  color: var(--color-primary);
  font-weight: 600;
  font-family: var(--font-heading);
  font-size: 0.9rem;
}

/* Form */
.contact-form-wrap {
  background: var(--color-white);
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
}
.form-header {
  background: linear-gradient(135deg, var(--color-secondary), #2b5289);
  padding: 28px 32px;
}
.form-header h3 {
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 1.3rem;
  color: white;
  margin-bottom: 6px;
}
.form-header p { color: rgba(255,255,255,0.7); font-size: 0.9rem; }

.contact-form { padding: 32px; display: flex; flex-direction: column; gap: 20px; }
.form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
.form-group { display: flex; flex-direction: column; gap: 6px; }
.form-group label {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 0.85rem;
  color: var(--color-secondary);
}
.form-group input,
.form-group select,
.form-group textarea {
  padding: 12px 16px;
  border: 2px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--color-text);
  outline: none;
  transition: border-color var(--transition);
  background: var(--color-white);
}
.form-group input:focus,
.form-group select:focus,
.form-group textarea:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(249,115,22,0.1);
}
.form-group textarea { resize: vertical; min-height: 100px; }

.submit-btn { width: 100%; justify-content: center; font-size: 1rem; padding: 16px; }
.form-note { font-size: 0.82rem; color: var(--color-text-muted); text-align: center; }
.form-success {
  display: flex;
  align-items: flex-start;
  gap: 16px;
  background: #eef9f0;
  border: 2px solid #22c55e;
  border-radius: var(--radius-md);
  padding: 20px;
}
.form-success span { font-size: 1.5rem; }
.form-success strong { display: block; color: #15803d; font-family: var(--font-heading); margin-bottom: 4px; }
.form-success p { font-size: 0.9rem; color: var(--color-text-muted); }

@media (max-width: 900px) {
  .contact-grid { grid-template-columns: 1fr; }
}
@media (max-width: 600px) {
  .form-row { grid-template-columns: 1fr; }
  .contact-form { padding: 24px; }
}
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.submit-btn') as HTMLButtonElement;
    const btnText = form.querySelector('.btn-text') as HTMLElement;
    const btnLoading = form.querySelector('.btn-loading') as HTMLElement;

    btn.disabled = true;
    btnText.style.display = 'none';
    btnLoading.style.display = 'inline';

    // Simulate submission — replace with Netlify Forms, Formspree, or your backend
    await new Promise(r => setTimeout(r, 1200));

    if (success) success.style.display = 'flex';
    form.reset();
    btn.disabled = false;
    btnText.style.display = 'inline';
    btnLoading.style.display = 'none';
  });
</script>
