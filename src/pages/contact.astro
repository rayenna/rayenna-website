---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Contact us – Rayenna Solar" description="Contact Rayenna Energy for a free solar consultation in Kochi, Kerala. Call, email or fill the form and we'll get back to you.">

  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <img src={`${base}/media/hero-copy.webp`} alt="" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__inner">
      <h1 class="page-hero__title">Contact Us</h1>
    </div>
  </section>

  <!-- ===== CONTACT SECTION ===== -->
  <section class="contact-section">
    <div class="container contact-section__inner">

      <!-- Form -->
      <div class="contact-form-wrap">
        <div class="contact-form-header">
          <h2 class="section-title contact-heading">Let's talk about<br /><span>your solar project!</span></h2>
          <p>Please do not hesitate to contact us if you are interested in exploring solar energy solutions or have any concerns. Our team is glad to assist you, whether you are seeking more details, requesting a quote, or scheduling a consultation. Call us at <a href="tel:+917907369304">+91 7907 369 304</a>, send us an email at <a href="mailto:sales@rayenna.energy">sales@rayenna.energy</a>, or visit our office. We take delight in providing tailored solutions and reliable services that ensure a seamless experience from start to finish. Get in touch with us and let's work together to power your world with renewable energy. We look forward to hearing from you!</p>
        </div>

        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <input type="text" id="name" name="name" placeholder="Your Name" required />
            </div>
            <div class="form-group">
              <input type="email" id="email" name="email" placeholder="Email Address" />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <input type="tel" id="phone" name="phone" placeholder="Phone Number" required />
            </div>
            <div class="form-group">
              <input type="text" id="subject" name="subject" placeholder="Subject" />
            </div>
          </div>
          <div class="form-group">
            <textarea id="message" name="message" rows="5" placeholder="Your message..."></textarea>
          </div>
          <button type="submit" class="btn btn-primary contact-submit">Send</button>
          <div class="form-success" id="form-success" style="display:none">
            Thank you! We'll get back to you shortly.
          </div>
        </form>
      </div>

      <!-- Info -->
      <div class="contact-info">
        <div class="contact-info__block">
          <ul class="contact-details">
            <li>
              <div class="contact-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
              </div>
              <div>
                <strong>Address</strong>
                <p>No. 3324/52, Ray Bhavan, NH Bypass,<br />Thykoodam, Vyttila,<br />Ernakulam, Kerala, India, 682019</p>
              </div>
            </li>
            <li>
              <div class="contact-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.69 3.18 2 2 0 0 1 3.68 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.69A16 16 0 0 0 16 16.61l1.06-1.06a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <strong>Phone</strong>
                <p><a href="tel:+917907369304">+91 7907 369 304</a></p>
              </div>
            </li>
            <li>
              <div class="contact-icon">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <strong>Email</strong>
                <p><a href="mailto:sales@rayenna.energy">sales@rayenna.energy</a></p>
              </div>
            </li>
          </ul>
        </div>
        <div class="contact-info__image">
          <img src={`${base}/media/glass-BG.webp`} alt="Rayenna office" />
        </div>
      </div>

    </div>
  </section>

</Layout>

<style>
/* ===== PAGE HERO ===== */
.page-hero {
  position: relative;
  height: 320px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.page-hero__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  z-index: 0;
}
.page-hero__overlay {
  position: absolute;
  inset: 0;
  background: rgba(10, 30, 55, 0.65);
  z-index: 1;
}
.page-hero__inner {
  position: relative;
  z-index: 2;
  padding-top: 72px;
}
.page-hero__title {
  font-family: var(--font-heading);
  font-size: clamp(2rem, 4vw, 3rem);
  font-weight: 500;
  color: white;
  letter-spacing: 1px;
}

/* ===== CONTACT SECTION ===== */
.contact-section {
  padding: var(--section-padding);
  background: var(--color-light);
}
.contact-section__inner {
  display: grid;
  grid-template-columns: 1.2fr 1fr;
  gap: 64px;
  align-items: start;
}

/* ===== FORM ===== */
.contact-form-header {
  margin-bottom: 40px;
}
.contact-heading {
  margin-bottom: 20px;
}
.contact-heading span { color: var(--color-primary); }
.contact-form-header p {
  color: var(--color-text-muted);
  line-height: 1.9;
  font-size: 0.95rem;
}
.contact-form-header a {
  color: var(--color-primary);
  font-weight: 600;
}
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
  background: var(--color-white);
  padding: 32px;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.form-group { display: flex; flex-direction: column; }
.form-group input,
.form-group textarea {
  padding: 14px 18px;
  border: 2px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--color-text);
  outline: none;
  transition: border-color var(--transition);
  background: var(--color-white);
}
.form-group input:focus,
.form-group textarea:focus {
  border-color: var(--color-primary);
  box-shadow: 0 0 0 3px rgba(168,56,56,0.1);
}
.form-group textarea { resize: vertical; min-height: 120px; }
.contact-submit {
  align-self: flex-start;
  padding: 14px 48px;
  font-size: 1rem;
}
.form-success {
  background: #eef9f0;
  border: 2px solid #22c55e;
  border-radius: var(--radius-md);
  padding: 16px 20px;
  color: #15803d;
  font-family: var(--font-heading);
  font-weight: 600;
}

/* ===== CONTACT INFO ===== */
.contact-details {
  display: flex;
  flex-direction: column;
  gap: 28px;
  margin-bottom: 36px;
}
.contact-details li {
  display: flex;
  align-items: flex-start;
  gap: 16px;
}
.contact-icon {
  width: 44px;
  height: 44px;
  background: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: white;
  flex-shrink: 0;
}
.contact-details strong {
  display: block;
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-secondary);
  margin-bottom: 4px;
  font-size: 0.9rem;
  text-transform: uppercase;
  letter-spacing: 1px;
}
.contact-details p {
  color: var(--color-text-muted);
  font-size: 0.95rem;
  line-height: 1.7;
}
.contact-details a {
  color: var(--color-primary);
  font-weight: 600;
  transition: color var(--transition);
}
.contact-details a:hover { color: var(--color-primary-dark); }

.contact-info__image img {
  width: 100%;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  object-fit: cover;
  max-height: 260px;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 900px) {
  .contact-section__inner {
    grid-template-columns: 1fr;
    gap: 48px;
  }
}
@media (max-width: 600px) {
  .form-row { grid-template-columns: 1fr; }
  .contact-form { padding: 24px; }
}
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.contact-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending...';

    await new Promise(r => setTimeout(r, 1000));

    if (success) success.style.display = 'block';
    form.reset();
    btn.disabled = false;
    btn.textContent = 'Send';
  });
</script>
