---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Contact us – Rayenna Solar" description="Contact Rayenna Energy for a free solar consultation in Kochi, Kerala. Call, email or fill the form and we'll get back to you.">

  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <img src={`${base}/media/Plan-solar.webp`} alt="Rayenna Energy contact" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__inner">
      <p class="page-hero__eyebrow">Get in Touch</p>
      <h1 class="page-hero__title">Let's Talk About<br />Your Solar Project</h1>
      <p class="page-hero__sub">Our team is ready to help you switch to clean, affordable solar energy — from first question to final installation.</p>
    </div>
  </section>

  <!-- ===== QUICK CONTACT STRIP ===== -->
  <section class="contact-strip">
    <div class="container contact-strip__inner">
      <a href="tel:+917907369304" class="strip-item">
        <div class="strip-item__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.69 3.18 2 2 0 0 1 3.68 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.69A16 16 0 0 0 16 16.61l1.06-1.06a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        </div>
        <div>
          <span class="strip-item__label">Call Us</span>
          <strong>+91 7907 369 304</strong>
        </div>
      </a>
      <div class="strip-divider"></div>
      <a href="mailto:sales@rayenna.energy" class="strip-item">
        <div class="strip-item__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        </div>
        <div>
          <span class="strip-item__label">Email Us</span>
          <strong>sales@rayenna.energy</strong>
        </div>
      </a>
      <div class="strip-divider"></div>
      <div class="strip-item">
        <div class="strip-item__icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
        </div>
        <div>
          <span class="strip-item__label">Visit Us</span>
          <strong>Vyttila, Ernakulam, Kerala</strong>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== MAIN CONTACT SECTION ===== -->
  <section class="contact-section">
    <div class="container contact-section__inner">

      <!-- Left: Form -->
      <div class="form-col">
        <div class="form-col__header">
          <span class="section-tag">Send a Message</span>
          <h2 class="section-title">Let's connect and<br /><span>power your world</span></h2>
          <p>Please do not hesitate to contact us if you are interested in exploring solar energy solutions or have any concerns. We take delight in providing tailored solutions and reliable services that ensure a seamless experience from start to finish.</p>
        </div>

        <form class="contact-form" id="contact-form">
          <div class="form-row">
            <div class="form-group">
              <label for="name">Your Name <span>*</span></label>
              <input type="text" id="name" name="name" placeholder="e.g. Rahul Menon" required />
            </div>
            <div class="form-group">
              <label for="phone">Phone Number <span>*</span></label>
              <input type="tel" id="phone" name="phone" placeholder="+91 98765 43210" required />
            </div>
          </div>
          <div class="form-row">
            <div class="form-group">
              <label for="email">Email Address</label>
              <input type="email" id="email" name="email" placeholder="you@example.com" />
            </div>
            <div class="form-group">
              <label for="subject">Subject</label>
              <input type="text" id="subject" name="subject" placeholder="e.g. Domestic Solar Quote" />
            </div>
          </div>
          <div class="form-group">
            <label for="message">Your Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Tell us about your property, current electricity bill, and what you're looking for..."></textarea>
          </div>
          <div class="form-footer">
            <button type="submit" class="btn btn-primary contact-submit">
              Send Message
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            </button>
            <div class="form-success" id="form-success" style="display:none">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
              Thank you! We'll get back to you within 24 hours.
            </div>
          </div>
        </form>
      </div>

      <!-- Right: Info card -->
      <div class="info-col">
        <div class="info-card">
          <h3 class="info-card__title">Visit Our Office</h3>
          <address class="info-address">
            No. 3329/52, Ray Bhavan,<br />
            NH Bypass, Thykoodam,<br />
            Vyttila, Ernakulam,<br />
            Kerala, India — 682019
          </address>

          <ul class="info-list">
            <li>
              <div class="info-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.69 3.18 2 2 0 0 1 3.68 1h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.69A16 16 0 0 0 16 16.61l1.06-1.06a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              </div>
              <div>
                <span class="info-label">Phone</span>
                <a href="tel:+917907369304">+91 7907 369 304</a>
              </div>
            </li>
            <li>
              <div class="info-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              </div>
              <div>
                <span class="info-label">Email</span>
                <a href="mailto:sales@rayenna.energy">sales@rayenna.energy</a>
              </div>
            </li>
          </ul>

          <div class="info-hours">
            <h4>Business Hours</h4>
            <p>Monday – Saturday<br /><strong>9:00 AM – 6:00 PM IST</strong></p>
          </div>

          <a
            href="https://www.google.com/maps/place/Rayenna+Energy+Private+Limited/@9.9582784,76.3156774,17z/data=!3m1!4b1!4m6!3m5!1s0x3b08730fe2f262fd:0xfe3741e3a2de18d8!8m2!3d9.9582784!4d76.3182523!16s%2Fg%2F11wmyllt0y?entry=ttu&g_ep=EgoyMDI2MDQyMi4wIKXMDSoASAFQAw%3D%3D"
            target="_blank"
            rel="noopener"
            class="directions-link"
          >
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polygon points="3 11 22 2 13 21 11 13 3 11"/></svg>
            Get Directions on Google Maps
          </a>
        </div>

        <img src={`${base}/media/Plan-solar.webp`} alt="Rayenna solar planning" class="info-image" />
      </div>

    </div>
  </section>

</Layout>

<style>
/* ===========================
   Contact Page — Mobile First
   =========================== */

/* ===== PAGE HERO ===== */
.page-hero {
  position: relative;
  min-height: 420px;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  padding-bottom: 56px;
}
.page-hero__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 30%;
  z-index: 0;
}
.page-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(10, 25, 50, 0.92) 0%,
    rgba(10, 25, 50, 0.6) 50%,
    rgba(10, 25, 50, 0.2) 100%
  );
  z-index: 1;
}
.page-hero__inner {
  position: relative;
  z-index: 2;
  padding-top: 88px;
}
.page-hero__eyebrow {
  font-size: 0.78rem;
  font-weight: 500;
  letter-spacing: 2.5px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.65);
  margin-bottom: 10px;
}
.page-hero__title {
  font-family: var(--font-heading);
  font-size: clamp(2.2rem, 5vw, 3.6rem);
  font-weight: 500;
  color: #ffffff;
  line-height: 1.2;
  margin-bottom: 14px;
}
.page-hero__sub {
  font-size: clamp(0.95rem, 2vw, 1.05rem);
  color: rgba(255,255,255,0.72);
  max-width: 500px;
  line-height: 1.75;
}

/* ===== CONTACT STRIP ===== */
.contact-strip {
  background: var(--color-navy);
  padding: 0;
}
.contact-strip__inner {
  display: flex;
  flex-direction: column;
  gap: 0;
}
.strip-item {
  display: flex;
  align-items: center;
  gap: 16px;
  padding: 22px 0;
  color: rgba(255,255,255,0.85);
  text-decoration: none;
  transition: color var(--transition);
  border-bottom: 1px solid rgba(255,255,255,0.08);
}
.strip-item:last-child { border-bottom: none; }
.strip-item:hover { color: #ffffff; }
.strip-item__icon {
  width: 46px;
  height: 46px;
  border-radius: 50%;
  background: rgba(255,255,255,0.1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  color: var(--color-primary);
  transition: background var(--transition);
}
.strip-item:hover .strip-item__icon { background: var(--color-primary); color: #fff; }
.strip-item__label {
  display: block;
  font-size: 0.72rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: 3px;
}
.strip-item strong {
  display: block;
  font-family: var(--font-heading);
  font-weight: 500;
  font-size: 0.95rem;
  color: #ffffff;
}
.strip-divider { display: none; }

/* ===== MAIN CONTACT SECTION ===== */
.contact-section {
  padding: var(--section-padding);
  background: var(--color-light);
}
.contact-section__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  align-items: start;
}

/* ===== FORM COLUMN ===== */
.form-col__header {
  margin-bottom: 36px;
}
.form-col__header .section-title {
  margin: 12px 0 16px;
}
.form-col__header .section-title span { color: var(--color-primary); }
.form-col__header p {
  color: var(--color-text-muted);
  line-height: 1.85;
  font-size: 0.95rem;
}
.contact-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
  background: #ffffff;
  padding: 32px 28px;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
  border-top: 4px solid var(--color-primary);
}
.form-row {
  display: grid;
  grid-template-columns: 1fr;
  gap: 16px;
}
.form-group {
  display: flex;
  flex-direction: column;
  gap: 6px;
}
.form-group label {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-navy);
  letter-spacing: 0.5px;
  text-transform: uppercase;
}
.form-group label span { color: var(--color-primary); }
.form-group input,
.form-group textarea {
  padding: 13px 16px;
  border: 2px solid var(--color-border);
  border-radius: var(--radius-sm);
  font-family: var(--font-body);
  font-size: 0.95rem;
  color: var(--color-text);
  outline: none;
  transition: border-color var(--transition), box-shadow var(--transition);
  background: var(--color-light);
  width: 100%;
}
.form-group input:focus,
.form-group textarea:focus {
  border-color: var(--color-primary);
  background: #ffffff;
  box-shadow: 0 0 0 3px rgba(168,56,56,0.08);
}
.form-group textarea { resize: vertical; min-height: 130px; }
.form-footer {
  display: flex;
  align-items: center;
  gap: 20px;
  flex-wrap: wrap;
  margin-top: 4px;
}
.contact-submit {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 14px 36px;
  font-size: 0.95rem;
}
.form-success {
  display: flex;
  align-items: center;
  gap: 10px;
  background: #f0faf4;
  border: 2px solid #22c55e;
  border-radius: var(--radius-md);
  padding: 14px 18px;
  color: #15803d;
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 0.9rem;
}

/* ===== INFO COLUMN ===== */
.info-card {
  background: var(--color-navy);
  color: rgba(255,255,255,0.82);
  border-radius: var(--radius-lg);
  padding: 36px 32px;
  margin-bottom: 20px;
}
.info-card__title {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 1.15rem;
  color: #ffffff;
  margin-bottom: 16px;
  padding-bottom: 16px;
  border-bottom: 1px solid rgba(255,255,255,0.12);
}
.info-address {
  font-style: normal;
  font-size: 0.92rem;
  line-height: 1.9;
  color: rgba(255,255,255,0.75);
  margin-bottom: 28px;
}
.info-list {
  display: flex;
  flex-direction: column;
  gap: 18px;
  margin-bottom: 28px;
}
.info-list li {
  display: flex;
  align-items: flex-start;
  gap: 14px;
}
.info-icon {
  width: 38px;
  height: 38px;
  background: rgba(255,255,255,0.08);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--color-primary);
  flex-shrink: 0;
}
.info-label {
  display: block;
  font-size: 0.7rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.45);
  margin-bottom: 3px;
}
.info-list a {
  color: rgba(255,255,255,0.85);
  font-size: 0.92rem;
  font-weight: 500;
  transition: color var(--transition);
}
.info-list a:hover { color: var(--color-primary); }
.info-hours {
  background: rgba(255,255,255,0.06);
  border-radius: var(--radius-md);
  padding: 16px 18px;
  margin-bottom: 24px;
}
.info-hours h4 {
  font-family: var(--font-heading);
  font-size: 0.72rem;
  font-weight: 700;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.5);
  margin-bottom: 6px;
}
.info-hours p {
  font-size: 0.9rem;
  color: rgba(255,255,255,0.75);
  line-height: 1.6;
}
.info-hours strong { color: #ffffff; }
.directions-link {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  font-family: var(--font-heading);
  font-size: 0.85rem;
  font-weight: 600;
  color: var(--color-primary);
  transition: gap var(--transition);
}
.directions-link:hover { gap: 11px; }

.info-image {
  width: 100%;
  height: 220px;
  object-fit: cover;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md);
}

/* ===========================
   Breakpoints — tablet+
   =========================== */
@media (min-width: 640px) {
  .form-row { grid-template-columns: 1fr 1fr; }
  .contact-strip__inner {
    flex-direction: row;
    align-items: center;
  }
  .strip-item {
    flex: 1;
    border-bottom: none;
    justify-content: center;
  }
  .strip-divider {
    display: block;
    width: 1px;
    height: 48px;
    background: rgba(255,255,255,0.12);
    flex-shrink: 0;
  }
}

@media (min-width: 960px) {
  .contact-section__inner {
    grid-template-columns: 1.3fr 1fr;
    gap: 64px;
  }
}
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const success = document.getElementById('form-success');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.contact-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending…';

    await new Promise(r => setTimeout(r, 1000));

    if (success) success.style.display = 'flex';
    form.reset();
    btn.disabled = false;
    btn.innerHTML = 'Send Message <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>';
  });
</script>
