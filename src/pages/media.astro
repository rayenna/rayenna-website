---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const installations = [
  { name: 'Abdul Rahim',  location: 'Edathala',      capacity: '5 kW',  inverter: 'Solaire',  panels: 'Adani',  img: 'ABDUL-RAHIMEDATHALA5KW-SOLAIRE-INVERTER-PANELS-ADANI-1.jpeg' },
  { name: 'Byju George',  location: 'Thevara',       capacity: '10 kW', inverter: 'Solis',    panels: 'Waaree', img: 'BYJU-GEORGE10KWTHEVARA-SOLIS-INVERTER-PANELS-WAAREE-1.jpeg' },
  { name: 'Francis',      location: 'Palluruthy',    capacity: '5 kW',  inverter: 'Solis',    panels: 'Adani',  img: 'FRANCISPALLURUTHY5KW-SOLIS-INVERTER-PANELS-ADANI.jpeg' },
  { name: 'Hyder',        location: 'Edapally',      capacity: '5 kW',  inverter: 'Solis',    panels: 'Waaree', img: 'HYDEREDAPALLY5KW-SOLIS-INVERTER-PANELS-WAAREE.jpeg' },
  { name: 'Jelees',       location: 'Mahe',          capacity: '5 kW',  inverter: 'Feston',   panels: 'Waaree', img: 'JELEESMAHE5KW-FESTON-INVERTER-PANELS-WAAREE-1.jpeg' },
  { name: 'Joby',         location: 'Chalakudy',     capacity: '3 kW',  inverter: 'Deye',     panels: 'Adani',  img: 'JOBYCHALAKUDY3KW-DEYE-INVERTER-PANELS-ADANI.jpeg' },
  { name: 'Rosa',         location: 'Vyttila',       capacity: '15 kW', inverter: 'Solaire',  panels: 'Waaree', img: 'ROSAVYTTILA15KW-SOLAIRE-INVERTER-PANELS-WAAREE-1.jpeg' },
  { name: 'Rupesh',       location: 'Calicut',       capacity: '3 kW',  inverter: 'Deye',     panels: 'Adani',  img: 'RUPESHCALICUT3KW-DEYE-INVERTER-PANELS-ADANI-edited.jpeg' },
  { name: 'Sajiv Kumar',  location: 'Vennala',       capacity: '5 kW',  inverter: 'Havells',  panels: 'Emmvee', img: 'SAJIVKUMARVENNALA5KW-HAVELLS-INVERTER-PANELS-EMMVEE-1.jpeg' },
  { name: 'Saphiya',      location: 'Edapally',      capacity: '5 kW',  inverter: 'Solis',    panels: 'Waaree', img: 'SAPHIYAEDAPALLY5KW-SOLIS-INVERTER-PANELS-WAAREE-1.jpeg' },
  { name: 'Vishnu T.V.',  location: 'Mulanthuruthy', capacity: '5 kW',  inverter: 'Growatt',  panels: 'Adani',  img: 'VISHNU-TVMULANTHURUTHY5KW-GROWATT-INVERTERPANELS-ADANI.jpeg' },
];

const showcase = [
  'Gemini_Generated_Image_14u7k214u7k214u7-edited.png',
  'Gemini_Generated_Image_jhdbl7jhdbl7jhdb-edited.png',
  'Gemini_Generated_Image_14u7k214u7k214u7-1.png',
  'Gemini_Generated_Image_jhdbl7jhdbl7jhdb.png',
];
---
<Layout title="Media & References – Rayenna Solar" description="Explore Rayenna Energy's installation gallery, project videos, and growing portfolio of happy solar customers across Kerala.">

  <!-- ===== PAGE HERO ===== -->
  <section class="page-hero">
    <img
      src={`${base}/media/references/Gemini_Generated_Image_14u7k214u7k214u7.png`}
      alt="Rayenna Energy solar installations"
      class="page-hero__bg"
    />
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__inner">
      <p class="page-hero__eyebrow">Portfolio & References</p>
      <h1 class="page-hero__title">Our Work<br />Speaks for Itself</h1>
      <p class="page-hero__sub">Real installations. Real homes. Real savings. Browse our growing library of completed solar projects across Kerala.</p>
    </div>
  </section>


  <!-- ===== INSTALLATION GALLERY ===== -->
  <section class="gallery-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Installation Gallery</span>
        <h2 class="section-title">Completed Projects</h2>
        <p class="section-intro">Every panel we install is a step towards a cleaner Kerala. Here are some of our recent projects — each delivered with precision, quality components, and care.</p>
      </div>

      <div class="gallery-grid">
        {installations.map((inst) => (
          <article class="gallery-card">
            <div class="gallery-card__img-wrap">
              <img
                src={`${base}/media/references/${inst.img}`}
                alt={`${inst.name} – ${inst.capacity} solar installation in ${inst.location}`}
                loading="lazy"
              />
              <div class="gallery-card__overlay">
                <span class="gallery-card__capacity">{inst.capacity}</span>
              </div>
            </div>
            <div class="gallery-card__info">
              <div class="gallery-card__name-row">
                <h3 class="gallery-card__name">{inst.name}</h3>
                <span class="gallery-card__location">
                  <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {inst.location}
                </span>
              </div>
              <div class="gallery-card__specs">
                <span class="spec-pill spec-pill--inverter">{inst.inverter} Inverter</span>
                <span class="spec-pill spec-pill--panels">{inst.panels} Panels</span>
              </div>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FEATURED VIDEO ===== -->
  <section class="video-section">
    <div class="video-section__bg-text" aria-hidden="true">VIDEO</div>
    <div class="container">
      <div class="section-header section-header--light">
        <span class="section-tag section-tag--light">Featured Video</span>
        <h2 class="section-title section-title--light">Watch Our Work in Action</h2>
        <p class="section-intro section-intro--light">See a real Rayenna solar installation from start to finish — captured at Sudheer's home in Njarakkal.</p>
      </div>
      <div class="video-player-wrap">
        <div class="video-meta">
          <span class="video-meta__name">Sudheer — Njarakkal</span>
          <span class="video-meta__spec">3 kW · Solis Inverter · Adani Panels</span>
        </div>
        <video
          class="video-player"
          controls
          preload="metadata"
          poster={`${base}/media/references/RUPESHCALICUT3KW-DEYE-INVERTER-PANELS-ADANI-edited.jpeg`}
        >
          <source src={`${base}/media/references/SUDHEERNJARAKKAL3KW-SOLIS-INVERTER-PANELS-ADANI.mp4`} type="video/mp4" />
          Your browser does not support the video tag.
        </video>
      </div>
    </div>
  </section>

  <!-- ===== VISUAL SHOWCASE ===== -->
  <section class="showcase-section">
    <div class="container">
      <div class="section-header">
        <span class="section-tag">Visual Showcase</span>
        <h2 class="section-title">Solar — Beautifully Done</h2>
      </div>
      <div class="showcase-grid">
        {showcase.map((img, i) => (
          <div class={`showcase-item showcase-item--${i % 2 === 0 ? 'tall' : 'short'}`}>
            <img
              src={`${base}/media/references/${img}`}
              alt="Rayenna solar showcase"
              loading="lazy"
            />
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== TESTIMONIALS COMING SOON ===== -->
  <section class="testimonials-section">
    <div class="container testimonials-inner">
      <div class="testimonials-content">
        <span class="section-tag section-tag--light">Customer Stories</span>
        <h2 class="section-title section-title--light">Testimonials Coming Soon</h2>
        <p class="section-intro section-intro--light">We are currently collecting feedback from our growing family of solar adopters. Their stories — of savings, sustainability, and satisfaction — will be right here shortly.</p>
        <a href={`${base}/contact`} class="btn btn-primary testimonials-cta">Share Your Experience</a>
      </div>
      <div class="testimonials-graphic">
        <div class="testi-quote-icon">"</div>
        <div class="testi-placeholder-cards">
          <div class="testi-card testi-card--1">
            <div class="testi-avatar">A</div>
            <div class="testi-lines"><span></span><span></span></div>
          </div>
          <div class="testi-card testi-card--2">
            <div class="testi-avatar">B</div>
            <div class="testi-lines"><span></span><span></span></div>
          </div>
          <div class="testi-card testi-card--3">
            <div class="testi-avatar">S</div>
            <div class="testi-lines"><span></span><span></span></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA BANNER ===== -->
  <section class="cta-banner">
    <img src={`${base}/media/glass-BG.webp`} alt="" class="cta-banner__bg" />
    <div class="cta-banner__overlay"></div>
    <div class="container cta-banner__inner">
      <h2 class="cta-banner__title">Ready to Be Our Next Success Story?</h2>
      <p class="cta-banner__sub">Join the growing list of homes and businesses across Kerala powering their lives with clean solar energy from Rayenna.</p>
      <a href={`${base}/contact`} class="btn btn-primary cta-banner__btn">Get a Free Quote</a>
    </div>
  </section>

</Layout>

<style>
/* ===========================
   Media Page — Mobile First
   =========================== */

/* ===== HERO ===== */
.page-hero {
  position: relative;
  min-height: 460px;
  display: flex;
  align-items: flex-end;
  padding-bottom: 56px;
  overflow: hidden;
}
.page-hero__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center 40%;
  z-index: 0;
}
.page-hero__overlay {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to top,
    rgba(8, 20, 45, 0.95) 0%,
    rgba(8, 20, 45, 0.55) 55%,
    rgba(8, 20, 45, 0.15) 100%
  );
  z-index: 1;
}
.page-hero__inner {
  position: relative;
  z-index: 2;
  padding-top: 96px;
}
.page-hero__eyebrow {
  font-size: 0.75rem;
  font-weight: 500;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,0.6);
  margin-bottom: 12px;
}
.page-hero__title {
  font-family: var(--font-heading);
  font-size: clamp(2.4rem, 5.5vw, 4rem);
  font-weight: 500;
  color: #fff;
  line-height: 1.15;
  margin-bottom: 16px;
}
.page-hero__sub {
  font-size: clamp(0.95rem, 2vw, 1.05rem);
  color: rgba(255,255,255,0.7);
  max-width: 520px;
  line-height: 1.8;
}


/* ===== GALLERY SECTION ===== */
.gallery-section {
  padding: var(--section-padding);
  background: var(--color-light);
}
.section-header {
  text-align: center;
  margin-bottom: 48px;
}
.section-header .section-title { margin: 10px 0 14px; }
.section-intro {
  color: var(--color-text-muted);
  max-width: 600px;
  margin: 0 auto;
  line-height: 1.85;
  font-size: 0.95rem;
}

.gallery-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}

.gallery-card {
  background: #fff;
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-sm);
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}
.gallery-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
}
.gallery-card__img-wrap {
  position: relative;
  height: 220px;
  overflow: hidden;
}
.gallery-card__img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.5s ease;
}
.gallery-card:hover .gallery-card__img-wrap img {
  transform: scale(1.04);
}
.gallery-card__overlay {
  position: absolute;
  top: 12px;
  right: 12px;
}
.gallery-card__capacity {
  background: var(--color-primary);
  color: #fff;
  font-family: var(--font-heading);
  font-size: 0.75rem;
  font-weight: 700;
  letter-spacing: 1px;
  padding: 5px 12px;
  border-radius: 99px;
}
.gallery-card__info {
  padding: 18px 20px 20px;
}
.gallery-card__name-row {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  gap: 8px;
  margin-bottom: 10px;
  flex-wrap: wrap;
}
.gallery-card__name {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-navy);
}
.gallery-card__location {
  display: flex;
  align-items: center;
  gap: 4px;
  font-size: 0.78rem;
  color: var(--color-text-muted);
}
.gallery-card__specs {
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}
.spec-pill {
  font-size: 0.72rem;
  font-weight: 600;
  letter-spacing: 0.5px;
  padding: 4px 10px;
  border-radius: 99px;
}
.spec-pill--inverter {
  background: rgba(39,50,79,0.08);
  color: var(--color-navy);
}
.spec-pill--panels {
  background: rgba(168,56,56,0.08);
  color: var(--color-primary);
}

/* ===== VIDEO SECTION ===== */
.video-section {
  position: relative;
  background: var(--color-navy);
  padding: var(--section-padding);
  overflow: hidden;
}
.video-section__bg-text {
  position: absolute;
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  font-family: var(--font-heading);
  font-size: clamp(80px, 18vw, 220px);
  font-weight: 900;
  color: rgba(255,255,255,0.03);
  letter-spacing: 0.2em;
  white-space: nowrap;
  pointer-events: none;
  user-select: none;
}
.section-header--light { color: #fff; }
.section-tag--light {
  background: rgba(255,255,255,0.12);
  color: rgba(255,255,255,0.7);
}
.section-title--light { color: #fff; }
.section-intro--light {
  color: rgba(255,255,255,0.65);
}
.video-player-wrap {
  max-width: 860px;
  margin: 0 auto;
}
.video-meta {
  display: flex;
  align-items: center;
  gap: 16px;
  margin-bottom: 14px;
  flex-wrap: wrap;
}
.video-meta__name {
  font-family: var(--font-heading);
  font-weight: 600;
  color: #fff;
  font-size: 0.95rem;
}
.video-meta__spec {
  font-size: 0.8rem;
  color: rgba(255,255,255,0.5);
  padding-left: 16px;
  border-left: 1px solid rgba(255,255,255,0.2);
}
.video-player {
  width: 100%;
  border-radius: var(--radius-lg);
  box-shadow: 0 24px 60px rgba(0,0,0,0.5);
  display: block;
  max-height: 520px;
  background: #000;
}

/* ===== SHOWCASE SECTION ===== */
.showcase-section {
  padding: var(--section-padding);
  background: #fff;
}
.showcase-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  margin-top: 4px;
}
.showcase-item {
  border-radius: var(--radius-md);
  overflow: hidden;
  position: relative;
}
.showcase-item--tall { grid-row: span 2; }
.showcase-item img {
  width: 100%;
  height: 100%;
  min-height: 200px;
  object-fit: cover;
  display: block;
  transition: transform 0.5s ease;
}
.showcase-item:hover img { transform: scale(1.04); }

/* ===== TESTIMONIALS ===== */
.testimonials-section {
  background: var(--color-primary);
  padding: var(--section-padding);
  overflow: hidden;
}
.testimonials-inner {
  display: flex;
  flex-direction: column;
  gap: 48px;
}
.testimonials-content {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.testimonials-cta {
  align-self: flex-start;
  background: #fff;
  color: var(--color-primary);
  margin-top: 8px;
}
.testimonials-cta:hover {
  background: rgba(255,255,255,0.9);
}
.testimonials-graphic {
  position: relative;
}
.testi-quote-icon {
  font-family: Georgia, serif;
  font-size: 120px;
  line-height: 0.8;
  color: rgba(255,255,255,0.12);
  position: absolute;
  top: -20px;
  left: -10px;
  pointer-events: none;
}
.testi-placeholder-cards {
  display: flex;
  flex-direction: column;
  gap: 14px;
  padding-top: 20px;
}
.testi-card {
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(8px);
  border-radius: var(--radius-md);
  padding: 18px 20px;
  display: flex;
  align-items: center;
  gap: 14px;
}
.testi-card--1 { margin-left: 0; }
.testi-card--2 { margin-left: 24px; }
.testi-card--3 { margin-left: 12px; }
.testi-avatar {
  width: 42px;
  height: 42px;
  border-radius: 50%;
  background: rgba(255,255,255,0.2);
  display: flex;
  align-items: center;
  justify-content: center;
  font-family: var(--font-heading);
  font-weight: 700;
  font-size: 1rem;
  color: #fff;
  flex-shrink: 0;
}
.testi-lines {
  display: flex;
  flex-direction: column;
  gap: 7px;
  flex: 1;
}
.testi-lines span {
  display: block;
  height: 8px;
  background: rgba(255,255,255,0.2);
  border-radius: 99px;
}
.testi-lines span:first-child { width: 80%; }
.testi-lines span:last-child { width: 55%; }

/* ===== CTA BANNER ===== */
.cta-banner {
  position: relative;
  min-height: 340px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.cta-banner__bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  z-index: 0;
}
.cta-banner__overlay {
  position: absolute;
  inset: 0;
  background: rgba(10, 25, 55, 0.82);
  z-index: 1;
}
.cta-banner__inner {
  position: relative;
  z-index: 2;
  text-align: center;
  padding: 64px 24px;
}
.cta-banner__title {
  font-family: var(--font-heading);
  font-size: clamp(1.5rem, 3.5vw, 2.4rem);
  font-weight: 500;
  color: #fff;
  margin-bottom: 14px;
}
.cta-banner__sub {
  color: rgba(255,255,255,0.7);
  max-width: 520px;
  margin: 0 auto 28px;
  line-height: 1.8;
  font-size: 0.95rem;
}
.cta-banner__btn { padding: 14px 40px; }

/* ===========================
   Breakpoints
   =========================== */
@media (min-width: 540px) {
  .gallery-grid { grid-template-columns: 1fr 1fr; }
}

@media (min-width: 768px) {
  .showcase-grid { grid-template-columns: 1fr 1fr 1fr; gap: 16px; }
  .showcase-item--tall { grid-row: span 2; }
  .showcase-item img { min-height: 240px; }
  .testimonials-inner {
    flex-direction: row;
    align-items: center;
    gap: 64px;
  }
  .testimonials-content { flex: 1; }
  .testimonials-graphic { flex: 1; }
}

@media (min-width: 960px) {
  .gallery-grid { grid-template-columns: repeat(3, 1fr); gap: 28px; }
  .gallery-card__img-wrap { height: 240px; }
}
</style>
