---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Rayenna Energy — Solar Solutions in Kochi, Kerala">

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero__bg-shapes">
      <div class="shape shape-1"></div>
      <div class="shape shape-2"></div>
      <div class="shape shape-3"></div>
    </div>
    <div class="container hero__inner">
      <div class="hero__content animate-fade-up">
        <span class="section-tag">🌞 Kerala's Trusted Solar Partner</span>
        <h1 class="hero__title">Soar into a <span>Sunny</span> Tomorrow!</h1>
        <p class="hero__subtitle">Make a switch to solar energy for a sustainable lifestyle that cares for both the planet and your wallet. Partner with Rayenna Energy for future-ready energy solutions.</p>
        <div class="hero__actions">
          <a href="/services" class="btn btn-primary">See Our Services</a>
          <a href="/contact#callback" class="btn btn-outline">Get a Call Back</a>
        </div>
        <div class="hero__badges">
          <div class="badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            5–6 Year ROI
          </div>
          <div class="badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            20+ Year System Life
          </div>
          <div class="badge">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            Govt. Subsidised
          </div>
        </div>
      </div>
      <div class="hero__visual animate-fade-up-2">
        <div class="hero__sun-graphic">
          <div class="sun-core">☀</div>
          <div class="sun-ring sun-ring-1"></div>
          <div class="sun-ring sun-ring-2"></div>
          <div class="sun-ring sun-ring-3"></div>
          <div class="floating-stat stat-1">
            <strong>80%</strong>
            <span>Cost Drop</span>
          </div>
          <div class="floating-stat stat-2">
            <strong>22%</strong>
            <span>Efficiency</span>
          </div>
          <div class="floating-stat stat-3">
            <strong>300+</strong>
            <span>Sunny Days</span>
          </div>
        </div>
      </div>
    </div>
    <div class="hero__wave">
      <svg viewBox="0 0 1440 80" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z" fill="#f8f9fa"/>
      </svg>
    </div>
  </section>

  <!-- ===== WHY SOLAR ===== -->
  <section class="why-solar">
    <div class="container">
      <div class="why-solar__intro text-center">
        <span class="section-tag">The Smart Choice</span>
        <h2 class="section-title">Solar Power: The Bright Choice for <span>the Earth and You</span></h2>
        <p class="section-subtitle" style="margin: 0 auto;">Imagine a future where your energy choices empower both your home and the planet. Solar energy is not only efficient and sustainable, it brings peace of mind and long-term financial rewards.</p>
      </div>
      <div class="why-solar__grid">
        <div class="why-card">
          <div class="why-card__icon" style="background:#fff4ec; color:#f97316">💸</div>
          <h3>More Affordable</h3>
          <p>Solar panel prices have dropped by over <strong>80%</strong> in the last two decades, making it more affordable than ever before.</p>
        </div>
        <div class="why-card">
          <div class="why-card__icon" style="background:#eef9f0; color:#22c55e">⚡</div>
          <h3>More Efficient</h3>
          <p>Modern solar panels now boast efficiency rates of up to <strong>22%</strong>, maximizing energy output from every ray of sunlight.</p>
        </div>
        <div class="why-card">
          <div class="why-card__icon" style="background:#eff6ff; color:#3b82f6">☀</div>
          <h3>More Available</h3>
          <p>With over <strong>300 sunny days</strong> a year in India, solar power generation is consistently at its peak in our region.</p>
        </div>
        <div class="why-card">
          <div class="why-card__icon" style="background:#fdf4ff; color:#a855f7">🏛</div>
          <h3>Subsidised</h3>
          <p>Government incentives and subsidies further reduce installation costs, making it a truly smart financial move today.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="stats-section">
    <div class="container">
      <div class="stats-grid">
        <div class="stat-box">
          <div class="stat-number" data-target="20">0</div>
          <div class="stat-suffix">+</div>
          <div class="stat-label">Brands We Work With</div>
        </div>
        <div class="stat-box">
          <div class="stat-number" data-target="80">0</div>
          <div class="stat-suffix">%</div>
          <div class="stat-label">Reduction in Bills</div>
        </div>
        <div class="stat-box">
          <div class="stat-number" data-target="100">0</div>
          <div class="stat-suffix">%</div>
          <div class="stat-label">Client Satisfaction</div>
        </div>
        <div class="stat-box">
          <div class="stat-number" data-target="5">0</div>
          <div class="stat-suffix">–6 Yrs</div>
          <div class="stat-label">Return on Investment</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT SNIPPET ===== -->
  <section class="about-snippet">
    <div class="container about-snippet__inner">
      <div class="about-snippet__image">
        <div class="about-image-placeholder">
          <svg viewBox="0 0 400 300" xmlns="http://www.w3.org/2000/svg" width="100%">
            <rect width="400" height="300" fill="#f0f4f8" rx="16"/>
            <circle cx="200" cy="120" r="60" fill="#fff4ec" stroke="#f97316" stroke-width="3"/>
            <text x="200" y="130" text-anchor="middle" font-size="48">☀</text>
            <rect x="40" y="220" width="320" height="12" rx="6" fill="#e2e8f0"/>
            <rect x="80" y="242" width="240" height="8" rx="4" fill="#e2e8f0"/>
            <text x="200" y="285" text-anchor="middle" font-size="12" fill="#94a3b8" font-family="sans-serif">Solar panel illustration</text>
          </svg>
        </div>
        <div class="about-badge">
          <div class="about-badge__icon">🏆</div>
          <div>
            <strong>Trusted Provider</strong>
            <span>Since 2019</span>
          </div>
        </div>
      </div>
      <div class="about-snippet__content">
        <span class="section-tag">Who We Are</span>
        <h2 class="section-title">Kerala's Leading <span>Solar Energy</span> Solutions Provider</h2>
        <p>Rayenna Energy is dedicated to transforming the way you harness and use energy. The knowledge and experience of our leadership team are not only a benefit to Rayenna Energy but also the cornerstone upon which we establish our standing as a reliable supplier of solar energy solutions.</p>
        <p style="margin-top:16px;">Going solar is about more than simply saving money on electricity bills — it's about making the earth a better place for future generations. With a deep commitment to delivering high-quality solar installations that prioritise sustainability, efficiency, and affordability, we believe in creating a greener future.</p>
        <div class="about-snippet__features">
          <div class="feature-item">
            <div class="feature-check">✓</div>
            <span>Certified & experienced installation team</span>
          </div>
          <div class="feature-item">
            <div class="feature-check">✓</div>
            <span>Premium brand solar panels & inverters</span>
          </div>
          <div class="feature-item">
            <div class="feature-check">✓</div>
            <span>Real-time online monitoring systems</span>
          </div>
          <div class="feature-item">
            <div class="feature-check">✓</div>
            <span>End-to-end service from design to support</span>
          </div>
        </div>
        <a href="/about" class="btn btn-primary mt-4">Read More About Us</a>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section class="process-section">
    <div class="container">
      <div class="text-center mb-4">
        <span class="section-tag">How It Works</span>
        <h2 class="section-title">Our Process for <span>Seamless Solar</span> Integration</h2>
      </div>
      <div class="process-grid">
        {[
          { num: '01', title: 'Consultation', desc: 'Through a customised consultation, we first ascertain your energy needs and goals to design the right solution for you.', icon: '💬' },
          { num: '02', title: 'Site Evaluation', desc: 'To identify the ideal solar solution for your property, our team thoroughly evaluates the site and its sun exposure.', icon: '🔍' },
          { num: '03', title: 'System Design', desc: 'We develop a unique solar system that optimises performance and efficiency based on the evaluation findings.', icon: '📐' },
          { num: '04', title: 'Installation', desc: 'Your solar system is built to the highest standards by our trained installers, who execute the process with accuracy.', icon: '⚙️' },
          { num: '05', title: 'Ongoing Support', desc: 'We offer ongoing maintenance and support to ensure that your system operates efficiently for decades to come.', icon: '🛡' },
        ].map(step => (
          <div class="process-card">
            <div class="process-card__num">{step.num}</div>
            <div class="process-card__icon">{step.icon}</div>
            <h3 class="process-card__title">{step.title}</h3>
            <p class="process-card__desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="cta-section" id="contact">
    <div class="container">
      <div class="cta-box">
        <div class="cta-content">
          <span class="section-tag" style="background:rgba(255,255,255,0.15); color:#fff;">Let's Connect!</span>
          <h2 class="cta-title">Ready to Make the Switch to Solar?</h2>
          <p>Contact us today for a free consultation and start your journey toward a more sustainable, cost-effective energy solution.</p>
        </div>
        <div class="cta-form">
          <form id="callback-form" action="/contact" method="GET">
            <input type="text" name="name" placeholder="Your Name" required />
            <input type="tel" name="phone" placeholder="Phone Number" required />
            <input type="text" name="city" placeholder="Your City" />
            <button type="submit" class="btn btn-primary" style="width:100%; justify-content:center;">
              Request a Call Back →
            </button>
          </form>
          <p class="cta-note">✓ Free consultation &nbsp;·&nbsp; ✓ No obligation &nbsp;·&nbsp; ✓ Response within 24 hrs</p>
        </div>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ===== HERO ===== */
.hero {
  background: linear-gradient(135deg, #1e3a5f 0%, #2b5289 50%, #1e3a5f 100%);
  padding: 140px 0 100px;
  position: relative;
  overflow: hidden;
  min-height: 100vh;
  display: flex;
  align-items: center;
}
.hero__bg-shapes { position: absolute; inset: 0; pointer-events: none; }
.shape {
  position: absolute;
  border-radius: 50%;
  opacity: 0.08;
  background: var(--color-primary);
}
.shape-1 { width: 600px; height: 600px; top: -200px; right: -100px; }
.shape-2 { width: 300px; height: 300px; bottom: -100px; left: 10%; background: white; opacity: 0.05; }
.shape-3 { width: 200px; height: 200px; top: 30%; left: -50px; }

.hero__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  position: relative;
  z-index: 1;
}
.hero__title {
  font-family: var(--font-heading);
  font-size: clamp(2.2rem, 4vw, 3.4rem);
  font-weight: 800;
  color: var(--color-white);
  line-height: 1.15;
  margin-bottom: 20px;
}
.hero__title span { color: var(--color-primary); }
.hero__subtitle {
  font-size: 1.1rem;
  color: rgba(255,255,255,0.8);
  margin-bottom: 32px;
  max-width: 520px;
  line-height: 1.8;
}
.hero__actions { display: flex; gap: 16px; flex-wrap: wrap; margin-bottom: 32px; }
.hero__badges { display: flex; gap: 20px; flex-wrap: wrap; }
.badge {
  display: flex;
  align-items: center;
  gap: 6px;
  color: rgba(255,255,255,0.9);
  font-size: 0.85rem;
  font-weight: 500;
}
.badge svg { color: var(--color-primary); flex-shrink: 0; }

/* Hero visual */
.hero__visual { display: flex; justify-content: center; align-items: center; }
.hero__sun-graphic {
  position: relative;
  width: 380px;
  height: 380px;
  display: flex;
  align-items: center;
  justify-content: center;
}
.sun-core {
  font-size: 5rem;
  z-index: 2;
  animation: float 4s ease-in-out infinite;
  filter: drop-shadow(0 0 30px rgba(249,115,22,0.5));
}
.sun-ring {
  position: absolute;
  border-radius: 50%;
  border: 2px solid rgba(249,115,22,0.2);
}
.sun-ring-1 { width: 150px; height: 150px; animation: pulse-ring 3s ease-out infinite; }
.sun-ring-2 { width: 240px; height: 240px; border-style: dashed; animation: float 6s ease-in-out infinite reverse; }
.sun-ring-3 { width: 340px; height: 340px; animation: float 8s ease-in-out infinite; }
.floating-stat {
  position: absolute;
  background: rgba(255,255,255,0.12);
  backdrop-filter: blur(8px);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 12px;
  padding: 12px 18px;
  text-align: center;
  color: white;
}
.floating-stat strong { display: block; font-size: 1.3rem; font-family: var(--font-heading); color: var(--color-primary); }
.floating-stat span { font-size: 0.75rem; opacity: 0.8; }
.stat-1 { top: 20px; right: 0; }
.stat-2 { bottom: 20px; right: 10px; }
.stat-3 { bottom: 60px; left: 0; }

.hero__wave { position: absolute; bottom: 0; left: 0; right: 0; line-height: 0; }
.hero__wave svg { width: 100%; display: block; }

/* ===== WHY SOLAR ===== */
.why-solar { padding: var(--section-padding); background: var(--color-light); }
.why-solar__intro { margin-bottom: 56px; }
.why-solar__grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 24px;
}
.why-card {
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 32px 24px;
  box-shadow: var(--shadow-sm);
  transition: all var(--transition);
  text-align: center;
}
.why-card:hover { transform: translateY(-6px); box-shadow: var(--shadow-md); }
.why-card__icon {
  width: 64px; height: 64px;
  border-radius: 16px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 1.8rem;
  margin: 0 auto 20px;
}
.why-card h3 {
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-secondary);
  margin-bottom: 12px;
}
.why-card p { font-size: 0.9rem; color: var(--color-text-muted); line-height: 1.7; }

/* ===== STATS ===== */
.stats-section {
  padding: 64px 0;
  background: linear-gradient(135deg, var(--color-primary) 0%, #ea6c00 100%);
}
.stats-grid {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 32px;
  text-align: center;
}
.stat-box { color: white; }
.stat-box .stat-number {
  font-family: var(--font-heading);
  font-size: clamp(2.5rem, 4vw, 3.5rem);
  font-weight: 800;
  display: inline-block;
}
.stat-box .stat-suffix {
  font-family: var(--font-heading);
  font-size: 1.4rem;
  font-weight: 700;
  display: inline-block;
}
.stat-label {
  font-size: 0.9rem;
  opacity: 0.85;
  margin-top: 6px;
  font-weight: 500;
}

/* ===== ABOUT SNIPPET ===== */
.about-snippet { padding: var(--section-padding); background: var(--color-white); }
.about-snippet__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 72px;
  align-items: center;
}
.about-snippet__image { position: relative; }
.about-image-placeholder {
  border-radius: var(--radius-lg);
  overflow: hidden;
  box-shadow: var(--shadow-lg);
}
.about-badge {
  position: absolute;
  bottom: -20px;
  right: -20px;
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 16px 24px;
  box-shadow: var(--shadow-md);
  display: flex;
  align-items: center;
  gap: 12px;
}
.about-badge__icon { font-size: 2rem; }
.about-badge strong { display: block; font-family: var(--font-heading); font-weight: 700; color: var(--color-secondary); }
.about-badge span { font-size: 0.85rem; color: var(--color-text-muted); }
.about-snippet__content p { color: var(--color-text-muted); line-height: 1.8; }
.about-snippet__features { display: flex; flex-direction: column; gap: 12px; margin-top: 28px; }
.feature-item { display: flex; align-items: center; gap: 12px; }
.feature-check {
  width: 24px; height: 24px;
  background: var(--color-primary-light);
  color: var(--color-primary);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 0.75rem;
  font-weight: 700;
  flex-shrink: 0;
}

/* ===== PROCESS ===== */
.process-section {
  padding: var(--section-padding);
  background: var(--color-light);
}
.process-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20px;
}
.process-card {
  background: var(--color-white);
  border-radius: var(--radius-md);
  padding: 28px 20px;
  box-shadow: var(--shadow-sm);
  position: relative;
  text-align: center;
  transition: all var(--transition);
}
.process-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
.process-card__num {
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--color-primary);
  color: white;
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 0.8rem;
  padding: 4px 12px;
  border-radius: 50px;
}
.process-card__icon { font-size: 2rem; margin: 16px 0 12px; }
.process-card__title {
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-secondary);
  margin-bottom: 10px;
  font-size: 1rem;
}
.process-card__desc { font-size: 0.85rem; color: var(--color-text-muted); line-height: 1.6; }

/* ===== CTA ===== */
.cta-section { padding: var(--section-padding); }
.cta-box {
  background: linear-gradient(135deg, var(--color-secondary) 0%, #1a3255 100%);
  border-radius: var(--radius-lg);
  padding: 64px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
  position: relative;
  overflow: hidden;
}
.cta-box::before {
  content: '☀';
  position: absolute;
  font-size: 20rem;
  right: 45%;
  top: 50%;
  transform: translateY(-50%);
  opacity: 0.03;
  pointer-events: none;
}
.cta-title {
  font-family: var(--font-heading);
  font-size: clamp(1.6rem, 2.5vw, 2.2rem);
  font-weight: 800;
  color: white;
  line-height: 1.25;
  margin: 12px 0 16px;
}
.cta-content p { color: rgba(255,255,255,0.75); line-height: 1.8; }
.cta-form { display: flex; flex-direction: column; gap: 14px; }
.cta-form input {
  padding: 14px 18px;
  border-radius: 50px;
  border: 2px solid rgba(255,255,255,0.15);
  background: rgba(255,255,255,0.1);
  color: white;
  font-family: var(--font-body);
  font-size: 0.95rem;
  outline: none;
  transition: border-color var(--transition);
}
.cta-form input::placeholder { color: rgba(255,255,255,0.5); }
.cta-form input:focus { border-color: var(--color-primary); }
.cta-note { font-size: 0.8rem; color: rgba(255,255,255,0.5); text-align: center; }

/* Responsive */
@media (max-width: 1100px) {
  .process-grid { grid-template-columns: repeat(3, 1fr); }
  .why-solar__grid { grid-template-columns: repeat(2, 1fr); }
}
@media (max-width: 768px) {
  .hero { padding: 120px 0 80px; min-height: auto; }
  .hero__inner { grid-template-columns: 1fr; gap: 40px; }
  .hero__visual { display: none; }
  .hero__actions { flex-direction: column; }
  .why-solar__grid { grid-template-columns: 1fr 1fr; }
  .stats-grid { grid-template-columns: 1fr 1fr; gap: 24px; }
  .about-snippet__inner { grid-template-columns: 1fr; }
  .about-badge { position: static; margin-top: 20px; }
  .process-grid { grid-template-columns: 1fr 1fr; }
  .cta-box { grid-template-columns: 1fr; padding: 40px 24px; gap: 32px; }
}
@media (max-width: 480px) {
  .why-solar__grid { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
  .process-grid { grid-template-columns: 1fr; }
}
</style>

<script>
  // Animated counter for stats section
  const observerOptions = { threshold: 0.5, rootMargin: '0px' };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const el = entry.target as HTMLElement;
        const target = parseInt(el.dataset.target || '0');
        let current = 0;
        const duration = 1500;
        const step = target / (duration / 16);
        const timer = setInterval(() => {
          current = Math.min(current + step, target);
          el.textContent = Math.floor(current).toString();
          if (current >= target) clearInterval(timer);
        }, 16);
        observer.unobserve(el);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.stat-number[data-target]').forEach(el => observer.observe(el));
</script>
