---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Rayenna Solar Kochi — The Responsible Energy Company">

  <!-- ===== HERO ===== -->
  <section class="hero">
    <img src={`${base}/media/hero (1).webp`} alt="Solar energy — child flying a kite" class="hero__photo" />
    <div class="hero__gradient"></div>
    <div class="hero__content">
      <h1 class="hero__title">Soar into a <br />Sunny Tomorrow!</h1>
      <div class="hero__mid">
        <img src={`${base}/media/Artboard-2mnre.webp`} alt="MNRE Approved Channel Partner — Govt of India" class="mnre-badge-img" />
        <p class="hero__subtitle">Make a switch to solar energy for a sustainable lifestyle that cares for both the planet and your wallet. Partner with Rayenna Energy for future-ready energy solutions that ensure you save on energy costs while reducing your carbon footprint.</p>
      </div>
      <div class="hero__actions">
        <a href={`${base}/services`} class="btn btn-hero-primary">See our Services</a>
        <a href={`${base}/contact`} class="btn btn-hero-outline">Get a call back</a>
      </div>
    </div>
  </section>

  <!-- ===== SOLAR POWER INTRO ===== -->
  <section class="solar-intro">
    <div class="container solar-intro__inner">
      <div class="solar-intro__image">
        <img src={`${base}/media/image.png`} alt="Solar energy growth chart" />
      </div>
      <div class="solar-intro__content">
        <h2 class="section-title">Solar Power: The Bright Choice for the Earth and You</h2>
        <p>Imagine a future where your energy choices empower both your home and the planet. Solar energy is not only efficient and sustainable, but it also brings peace of mind, knowing that with each watt you produce, you're contributing to a greener environment. With the right maintenance and care, your solar system can operate at peak efficiency for two decades, allowing you to enjoy the benefits of renewable energy. Best of all, you are guaranteed a return on your initial investment within 5 to 6 years, rendering it a prudent financial decision for both your property and the environment. Embrace the power of solar energy and watch your savings grow while contributing to a sustainable future!</p>
      </div>
    </div>
  </section>

  <!-- ===== WHO WE ARE ===== -->
  <section class="who-we-are">
    <div class="container who-we-are__inner">
      <div class="who-we-are__content">
        <h2 class="section-title">Who We Are</h2>
        <p>Rayenna Energy is a leading provider of innovative solar energy solutions dedicated to transforming the way you harness and use energy. The knowledge and experience of our leadership team are not only a benefit to Rayenna Energy but also the cornerstone upon which we establish our standing as a reliable supplier of solar energy solutions. Going solar is about more than simply saving money on electricity bills; it's about making the earth a better place for future generations. With a deep commitment to delivering high-quality solar installations that prioritise sustainability, efficiency, and affordability, we believe in creating a greener future.</p>
        <a href={`${base}/about`} class="read-more">Read more &gt;&gt;</a>
      </div>
      <div class="who-we-are__stats">
        <div class="stat-item">
          <div class="stat-wrap">
            <span class="stat-number" data-target="20">0</span>
            <span class="stat-suffix">+</span>
          </div>
          <p class="stat-label">Brands</p>
        </div>
        <div class="stat-item">
          <div class="stat-wrap">
            <span class="stat-number" data-target="80">0</span>
            <span class="stat-suffix">%</span>
          </div>
          <p class="stat-label">Less bills</p>
        </div>
        <div class="stat-item">
          <div class="stat-wrap">
            <span class="stat-number" data-target="100">0</span>
            <span class="stat-suffix">%</span>
          </div>
          <p class="stat-label">Client satisfaction</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== INVEST IN SOLAR ===== -->
  <section class="invest-section">
    <img src={`${base}/media/glass-BG.jpg`} alt="" class="invest-bg" />
    <div class="invest-overlay"></div>
    <div class="container invest-inner">
      <div class="invest-left">
        <h2 class="invest-title">This is the right time to invest in a solar panel</h2>
      </div>
      <div class="invest-cards">
        <div class="invest-card">
          <h3>More affordable</h3>
          <p>Solar panel prices have dropped by over 80% in the last two decades, making it more affordable than ever.</p>
        </div>
        <div class="invest-card">
          <h3>More efficient</h3>
          <p>Modern solar panels now boast efficiency rates of up to 22%, maximizing energy output.</p>
        </div>
        <div class="invest-card">
          <h3>More available</h3>
          <p>With over 300 sunny days a year in India, solar power generation is at its peak.</p>
        </div>
        <div class="invest-card">
          <h3>Subsidised</h3>
          <p>Government incentives and subsidies further reduce installation costs, making it a smart financial move today.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CHOOSING THE RAYENNA WAY ===== -->
  <section class="rayenna-way">
    <div class="container rayenna-way__inner">
      <div class="rayenna-way__image">
        <img src={`${base}/media/Hardshell-solar.webp`} alt="Rayenna solar quality" />
      </div>
      <div class="rayenna-way__content">
        <h2 class="section-title">Choosing the Rayenna Way</h2>
        <p>Quality is our priority at Rayenna. We make sure every solar system is constructed for dependability and long-term performance by using only the best materials. From design to installation, we customise our services to match your unique demands, emphasising accuracy and timeliness in every step. We provide real-time updates and prompt maintenance as needed using online monitoring systems, so you can feel supported even after the installation. Solar power is an easy, hassle-free, affordable alternative because of our commitment to excellent standards and smooth service.</p>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS ===== -->
  <section class="process-section">
    <div class="container">
      <div class="text-center" style="margin-bottom:56px">
        <h2 class="section-title">Our Process for Seamless Solar Integration</h2>
      </div>
      <div class="process-grid">
        {[
          { num: '01', title: 'Consultation', desc: 'Through a customised consultation, we first ascertain your energy needs and goals.' },
          { num: '02', title: 'Site Evaluation', desc: 'To identify the ideal solar solution for your property, our team thoroughly evaluates the site.' },
          { num: '03', title: 'System Design', desc: 'We develop a unique solar system that optimises performance and efficiency based on the evaluation.' },
          { num: '04', title: 'Installation', desc: 'Your solar system is built up to the highest standards by our trained installers, who execute the process with accuracy.' },
          { num: '05', title: 'Ongoing Support', desc: 'We offer ongoing maintenance and support to ensure that your system operates efficiently, enabling you to experience the advantages of solar energy without any concerns.' },
        ].map(step => (
          <div class="process-card">
            <div class="process-card__num">{step.num}</div>
            <h3 class="process-card__title">{step.title}</h3>
            <p class="process-card__desc">{step.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== MAP ===== -->
  <section class="map-section">
    <iframe
      class="map-iframe"
      src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3929.2!2d76.3156774!3d9.9582784!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x3b08730fe2f262fd%3A0xfe3741e3a2de18d8!2sRayenna%20Energy%20Private%20Limited!5e0!3m2!1sen!2sin!4v1"
      width="100%"
      height="380"
      style="border:0;"
      allowfullscreen=""
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      title="Rayenna Energy location on Google Maps"
    ></iframe>
  </section>

  <!-- ===== CALCULATOR CTA CARD ===== -->
  <section class="calc-cta-section">
    <div class="container">
      <div class="calc-cta-card">
        <span class="calc-cta-icon">☀️</span>
        <div class="calc-cta-content">
          <h2>Not sure what size solar system you need?</h2>
          <p>Use our free calculator — enter your home details and get a personalised recommendation in under 5 minutes.</p>
        </div>
        <a href={`${base}/calculator`} class="btn btn-primary calc-cta-btn">Try the Calculator →</a>
      </div>
    </div>
  </section>

  <!-- ===== LET'S CONNECT ===== -->
  <section class="connect-section">
    <div class="container connect-section__inner">
      <div class="connect-content">
        <h2 class="section-title connect-title">Let's Connect!</h2>
        <p>Ready to take the next step? Contact us today for a consultation and start your journey toward a more sustainable, cost-effective energy solution.</p>
      </div>
      <div class="connect-form-wrap">
        <form class="connect-form" id="connect-form">
          <input type="hidden" name="_subject" value="New Callback Request — Rayenna Website" />
          <input type="hidden" name="source" value="Homepage callback form" />
          <input type="text" name="name" placeholder="Your Name" required />
          <input type="tel" name="phone" placeholder="Phone Number" required />
          <input type="text" name="city" placeholder="Your City" />
          <button type="submit" class="btn btn-primary connect-submit">Get a call back</button>
          <p class="connect-form__feedback" id="connect-feedback" style="display:none"></p>
        </form>
      </div>
    </div>
  </section>

</Layout>

<style>
/* ===== HERO ===== */
.hero {
  position: relative;
  width: 100%;
  min-height: 92vh;
  display: flex;
  align-items: center;
  overflow: hidden;
  padding-top: 72px; /* navbar height */
}

/* Full-bleed photo across the entire hero */
.hero__photo {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: right center;
  z-index: 0;
}

/* Gradient gives readability across the wider content area */
.hero__gradient {
  position: absolute;
  inset: 0;
  background: linear-gradient(
    to right,
    rgba(255,255,255,0.65) 0%,
    rgba(255,255,255,0.55) 35%,
    rgba(255,255,255,0.2) 55%,
    rgba(255,255,255,0) 70%
  );
  z-index: 1;
}

/* Text content sits on the left over the white area */
.hero__content {
  position: relative;
  z-index: 2;
  max-width: 620px;
  width: 52%;
  padding: 60px 0 60px 6vw;
}

.hero__title {
  font-family: var(--font-heading);
  font-size: clamp(2.2rem, 4.5vw, 4rem);
  font-weight: 400;
  color: #a83838;
  line-height: 1.2;
  margin-bottom: 32px;
}

.hero__mid {
  display: flex;
  align-items: center;
  gap: 28px;
  margin-bottom: 36px;
}

/* ===== MNRE BADGE IMAGE ===== */
.mnre-badge-img {
  flex-shrink: 0;
  width: 150px;
  height: 150px;
  object-fit: contain;
}

.hero__subtitle {
  font-size: 1rem;
  color: #a83838;
  line-height: 1.75;
  flex: 1;
  min-width: 0;
}

.hero__actions {
  display: flex;
  gap: 20px;
  flex-wrap: wrap;
  align-items: center;
}

/* Hero-specific button overrides to match the maroon style */
.btn-hero-primary {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 38px;
  border-radius: 50px;
  font-family: var(--font-heading);
  font-weight: 500;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all var(--transition);
  text-decoration: none;
  background: #a83838;
  color: #fff;
  border: 2px solid #a83838;
}
.btn-hero-primary:hover {
  background: #8a2c2c;
  border-color: #8a2c2c;
  transform: translateY(-2px);
  box-shadow: 0 6px 20px rgba(168,56,56,0.35);
}
.btn-hero-outline {
  display: inline-flex;
  align-items: center;
  gap: 8px;
  padding: 12px 38px;
  border-radius: 50px;
  font-family: var(--font-heading);
  font-weight: 500;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all var(--transition);
  text-decoration: none;
  background: transparent;
  color: #a83838;
  border: 2px solid #a83838;
}
.btn-hero-outline:hover {
  background: #a83838;
  color: #fff;
  transform: translateY(-2px);
}

/* ===== SOLAR INTRO ===== */
.solar-intro {
  padding: var(--section-padding);
  background: #fdf8f0;
}
.solar-intro__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.solar-intro__image img {
  width: 100%;
  max-width: 528px;
  border-radius: var(--radius-md);
  box-shadow: var(--shadow-sm);
  object-fit: contain;
  background: #f5f5f5;
}
.solar-intro__content p {
  color: var(--color-text-muted);
  line-height: 1.9;
  font-size: 1rem;
}
.solar-intro__content .section-title {
  margin-bottom: 24px;
}

/* ===== WHO WE ARE ===== */
.who-we-are {
  padding: var(--section-padding);
  background: var(--color-light);
}
.who-we-are__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.who-we-are__content .section-title {
  margin-bottom: 20px;
}
.who-we-are__content p {
  color: var(--color-text-muted);
  line-height: 1.9;
  margin-bottom: 20px;
}
.read-more {
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-primary);
  font-size: 0.95rem;
  transition: color var(--transition);
}
.read-more:hover { color: var(--color-primary-dark); }

.who-we-are__stats {
  display: flex;
  flex-direction: column;
  gap: 40px;
  align-items: center;
}
.stat-item { text-align: center; }
.stat-wrap {
  display: flex;
  align-items: baseline;
  justify-content: center;
  gap: 2px;
}
.stat-number {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(3rem, 5vw, 5rem);
  font-weight: 600;
  color: #2a2a2a;
  line-height: 1;
}
.stat-suffix {
  font-family: 'Oswald', sans-serif;
  font-size: clamp(1.5rem, 2.5vw, 2.5rem);
  font-weight: 500;
  color: #2a2a2a;
}
.stat-label {
  font-family: var(--font-heading);
  font-size: 0.8rem;
  font-weight: 600;
  color: var(--color-text-muted);
  margin-top: 8px;
  text-transform: uppercase;
  letter-spacing: 2px;
}

/* ===== INVEST IN SOLAR ===== */
.invest-section {
  position: relative;
  min-height: 520px;
  display: flex;
  align-items: center;
  overflow: hidden;
}
.invest-bg {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  object-position: center;
  z-index: 0;
}
.invest-overlay {
  position: absolute;
  inset: 0;
  background: rgba(10, 20, 45, 0.45);
  z-index: 1;
}
.invest-inner {
  position: relative;
  z-index: 2;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 48px;
  align-items: center;
  padding-top: 72px;
  padding-bottom: 72px;
}
.invest-left {
  padding-right: 24px;
}
.invest-title {
  font-family: var(--font-heading);
  font-size: clamp(1.8rem, 3.5vw, 3rem);
  font-weight: 400;
  color: #ffffff;
  line-height: 1.25;
}
.invest-cards {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 16px;
}
.invest-card {
  background: rgba(20, 35, 75, 0.65);
  backdrop-filter: blur(10px);
  -webkit-backdrop-filter: blur(10px);
  border: 1px solid rgba(255, 255, 255, 0.12);
  border-radius: var(--radius-md);
  padding: 28px 24px;
}
.invest-card h3 {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 1.05rem;
  color: #ffffff;
  margin-bottom: 10px;
  line-height: 1.3;
}
.invest-card p {
  font-size: 0.88rem;
  color: rgba(255, 255, 255, 0.82);
  line-height: 1.7;
}

/* ===== RAYENNA WAY ===== */
.rayenna-way {
  padding: var(--section-padding);
  background: var(--color-light);
}
.rayenna-way__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.rayenna-way__image img {
  width: 100%;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  object-fit: cover;
}
.rayenna-way__content .section-title { margin-bottom: 24px; }
.rayenna-way__content p {
  color: var(--color-text-muted);
  line-height: 1.9;
}

/* ===== PROCESS ===== */
.process-section {
  padding: var(--section-padding);
  background: var(--color-white);
}
.process-grid {
  display: grid;
  grid-template-columns: repeat(5, 1fr);
  gap: 20px;
}
.process-card {
  background: var(--color-light);
  border-radius: var(--radius-md);
  padding: 32px 20px 28px;
  position: relative;
  text-align: center;
  transition: all var(--transition);
}
.process-card:hover {
  transform: translateY(-4px);
  box-shadow: var(--shadow-md);
  background: var(--color-white);
}
.process-card__num {
  position: absolute;
  top: -14px;
  left: 50%;
  transform: translateX(-50%);
  background: var(--color-primary);
  color: white;
  font-family: var(--font-heading);
  font-weight: 800;
  font-size: 0.8rem;
  padding: 4px 14px;
  border-radius: 50px;
  white-space: nowrap;
}
.process-card__title {
  font-family: var(--font-heading);
  font-weight: 700;
  color: var(--color-secondary);
  margin-bottom: 12px;
  margin-top: 8px;
  font-size: 1.05rem;
}
.process-card__desc {
  font-size: 0.88rem;
  color: var(--color-text-muted);
  line-height: 1.7;
}

/* ===== MAP ===== */
.map-section {
  width: 100%;
  line-height: 0; /* removes inline gap below iframe */
}
.map-iframe {
  width: 100%;
  height: 380px;
  display: block;
  border: 0;
  filter: grayscale(60%) contrast(1.05);
  transition: filter 0.4s ease;
}
.map-iframe:hover {
  filter: grayscale(0%) contrast(1);
}
@media (max-width: 768px) {
  .map-iframe { height: 260px; }
}

/* ===== CALCULATOR CTA CARD ===== */
.calc-cta-section { padding: 48px 0; background: #fff; }
.calc-cta-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  gap: 20px;
  background: #E6F1FB;
  border: 1.5px solid #d0dce8;
  border-radius: 16px;
  padding: 32px 28px;
}
.calc-cta-icon { font-size: 2.8rem; line-height: 1; }
.calc-cta-content h2 {
  font-family: var(--font-heading);
  font-size: clamp(1.2rem, 2.5vw, 1.55rem);
  font-weight: 600;
  color: #1B2E5A;
  margin-bottom: 8px;
  line-height: 1.3;
}
.calc-cta-content p { font-size: 0.92rem; color: var(--color-text-muted); line-height: 1.7; margin: 0; }
.calc-cta-btn { align-self: flex-start; white-space: nowrap; }
@media (min-width: 768px) {
  .calc-cta-card {
    flex-direction: row;
    align-items: center;
    gap: 28px;
  }
  .calc-cta-content { flex: 1; }
}

/* ===== LET'S CONNECT ===== */
.connect-section {
  padding: var(--section-padding);
  background: var(--color-secondary);
}
.connect-section__inner {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 64px;
  align-items: center;
}
.connect-title {
  color: var(--color-white) !important;
  margin-bottom: 20px;
}
.connect-content p {
  color: rgba(255,255,255,0.8);
  line-height: 1.8;
}
.connect-form {
  display: flex;
  flex-direction: column;
  gap: 16px;
}
.connect-form input {
  padding: 14px 20px;
  border-radius: 50px;
  border: 2px solid rgba(255,255,255,0.2);
  background: rgba(255,255,255,0.1);
  color: white;
  font-family: var(--font-body);
  font-size: 0.95rem;
  outline: none;
  transition: border-color var(--transition);
}
.connect-form input::placeholder { color: rgba(255,255,255,0.5); }
.connect-form input:focus { border-color: var(--color-primary); }
.connect-submit {
  width: 100%;
  justify-content: center;
  font-size: 1rem;
}
.connect-form__feedback {
  color: #fca5a5;
  font-size: 0.85rem;
  margin-top: 8px;
  text-align: center;
}

/* ===== RESPONSIVE ===== */
@media (max-width: 1100px) {
  .process-grid { grid-template-columns: repeat(3, 1fr); }
}
@media (max-width: 900px) {
  .solar-intro__inner,
  .who-we-are__inner,
  .rayenna-way__inner,
  .connect-section__inner { grid-template-columns: 1fr; gap: 40px; }
  .who-we-are__stats { flex-direction: row; justify-content: space-around; }
  .rayenna-way__image { order: -1; }
  .invest-inner { grid-template-columns: 1fr; gap: 36px; }
  .invest-left { padding-right: 0; }
}
@media (max-width: 768px) {
  .hero {
    min-height: 100svh;
    align-items: flex-end;
    padding-bottom: 48px;
  }
  .hero__photo {
    object-position: center center;
    content: url('/media/hero-mobile.webp');
  }
  .hero__gradient {
    background: linear-gradient(
      to top,
      rgba(255,255,255,0.92) 0%,
      rgba(255,255,255,0.78) 40%,
      rgba(255,255,255,0.35) 70%,
      rgba(255,255,255,0) 100%
    );
  }
  .hero__content {
    padding: 0 24px;
    width: 100%;
    max-width: 100%;
  }
  .hero__title { font-size: 2.2rem; }
  .hero__actions { flex-direction: column; align-items: flex-start; }
  .process-grid { grid-template-columns: 1fr 1fr; }
  .invest-cards { grid-template-columns: 1fr; }
}
@media (max-width: 480px) {
  .process-grid { grid-template-columns: 1fr; }
  .who-we-are__stats { flex-direction: column; }
  .hero__mid { flex-direction: column; align-items: flex-start; gap: 16px; }
  .hero__subtitle { max-width: 100%; }
}
</style>

<script>
  const observerOptions = { threshold: 0.3 };
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      const el = entry.target as HTMLElement;
      if (entry.isIntersecting && !el.dataset.animated) {
        el.dataset.animated = 'true';
        observer.unobserve(el);
        const target = parseInt(el.dataset.target || '0');
        let current = 0;
        const duration = 1500;
        const step = target / (duration / 16);
        const timer = setInterval(() => {
          current = Math.min(current + step, target);
          el.textContent = Math.floor(current).toString();
          if (current >= target) clearInterval(timer);
        }, 16);
      }
    });
  }, observerOptions);

  document.querySelectorAll('.stat-number[data-target]').forEach(el => observer.observe(el));

  const form = document.getElementById('connect-form') as HTMLFormElement | null;
  const feedback = document.getElementById('connect-feedback');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const btn = form.querySelector('.connect-submit') as HTMLButtonElement;
    btn.disabled = true;
    btn.textContent = 'Sending…';
    if (feedback) feedback.style.display = 'none';

    try {
      const response = await fetch('https://formspree.io/f/xwvazrnw', {
        method: 'POST',
        headers: { 'Accept': 'application/json' },
        body: new FormData(form),
      });

      if (response.ok) {
        form.reset();
        btn.textContent = "✓ We'll call you soon!";
        if (feedback) { feedback.textContent = ''; feedback.style.display = 'none'; }
        setTimeout(() => {
          btn.textContent = 'Get a call back';
          btn.disabled = false;
        }, 4000);
      } else {
        btn.textContent = 'Get a call back';
        btn.disabled = false;
        if (feedback) {
          feedback.textContent = 'Something went wrong. Please try again.';
          feedback.style.display = 'block';
        }
      }
    } catch {
      btn.textContent = 'Get a call back';
      btn.disabled = false;
      if (feedback) {
        feedback.textContent = 'Network error. Please try again.';
        feedback.style.display = 'block';
      }
    }
  });
</script>
