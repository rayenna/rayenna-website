---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout
  title="Solar Calculator | Rayenna Energy — Find Your Perfect Solar System"
  description="Use Rayenna's free solar calculator to find out exactly how many panels you need, what they'll cost, and how fast they'll pay back. Personalised for Kerala homes."
>

  <!-- ===== HERO ===== -->
  <section class="page-hero">
    <img src={`${base}/media/services-hero-opt3.jpg`} alt="Solar panels on a rooftop at sunset" class="page-hero__bg" />
    <div class="page-hero__overlay"></div>
    <div class="container page-hero__inner">
      <p class="page-hero__eyebrow">Smart Solar Sizing Tool</p>
      <h1 class="page-hero__title">Find Out Exactly How Much Solar You Need</h1>
      <p class="page-hero__sub">Tell us about your home. We'll tell you exactly what to install.</p>
      <div class="hero-btns">
        <a href="#calculator" class="btn btn-primary hero-scroll-btn">Start the Calculator ↓</a>
        <a href={`${base}/contact`} class="btn btn-outline-white">Get a Free Consultation</a>
      </div>
    </div>
  </section>

  <!-- ===== TRUST STRIP ===== -->
  <section class="trust-strip">
    <div class="container trust-inner">
      {[
        { val: '5 min',  label: 'Time to complete' },
        { val: '100%',   label: 'Personalised results' },
        { val: 'Free',   label: 'No cost, no commitment' },
        { val: 'MNRE',   label: 'Approved installer' },
      ].map(m => (
        <div class="trust-metric">
          <strong>{m.val}</strong>
          <span>{m.label}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section class="calc-intro">
    <div class="container calc-intro__inner">
      <div class="calc-intro__image">
        <img src={`${base}/media/Hardshell-solar.webp`} alt="Solar system installation" />
      </div>
      <div class="calc-intro__content">
        <span class="section-tag">How it works</span>
        <h2 class="section-title">Your Home is Unique. Your Solar System Should Be Too.</h2>
        <p>Most solar quotes you receive are generic — based on averages, not your actual home. Rayenna's Solar Calculator changes that. Tell us about your home type, the rooms and floors you have, the appliances you run every day, and whether you charge an electric vehicle. Our calculator uses real consumption data to recommend the exact system size, panel type, and number of panels your home needs — along with a financial snapshot showing your payback period and 25-year savings. No guesswork. No salespeople. Just numbers.</p>
        <div class="how-cards">
          <div class="how-card">
            <span class="how-card__icon">⚡</span>
            <div>
              <h3>Enter your details</h3>
              <p>Home type, rooms, and appliances</p>
            </div>
          </div>
          <div class="how-card">
            <span class="how-card__icon">☀️</span>
            <div>
              <h3>Get your recommendation</h3>
              <p>System size, panels, and roof space</p>
            </div>
          </div>
          <div class="how-card">
            <span class="how-card__icon">💰</span>
            <div>
              <h3>See your savings</h3>
              <p>Payback period and lifetime savings</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CALCULATOR MODULE ===== -->
  <section class="calculator-section" id="calculator">
    <div class="container">
      <div class="calc-card">

        <!-- Progress bar -->
        <div class="calc-progress">
          <div class="calc-progress-bar">
            <div class="cpb-dot active" data-dot="1"><span>1</span></div>
            <div class="cpb-line" data-line="1"></div>
            <div class="cpb-dot" data-dot="2"><span>2</span></div>
            <div class="cpb-line" data-line="2"></div>
            <div class="cpb-dot" data-dot="3"><span>3</span></div>
            <div class="cpb-line" data-line="3"></div>
            <div class="cpb-dot" data-dot="4"><span>4</span></div>
          </div>
          <p class="calc-step-label" id="step-label">Step 1 of 4 — Your home</p>
        </div>

        <!-- ── STEP 1: HOME ── -->
        <div class="calc-step" id="step-1">
          <h3 class="calc-step-title">About Your Home</h3>

          <p class="calc-field-label">Home type</p>
          <div class="home-type-grid" id="home-type-grid">
            <div class="ht-card selected" data-type="house">
              <span class="ht-icon">🏠</span>
              <strong>Independent house</strong>
              <small>Standalone home</small>
            </div>
            <div class="ht-card" data-type="apartment">
              <span class="ht-icon">🏢</span>
              <strong>Apartment</strong>
              <small>Flat / unit in a building</small>
            </div>
            <div class="ht-card" data-type="villa">
              <span class="ht-icon">🏡</span>
              <strong>Villa</strong>
              <small>Detached / gated villa</small>
            </div>
            <div class="ht-card" data-type="rowhouse">
              <span class="ht-icon">🏘</span>
              <strong>Row house</strong>
              <small>Terraced / linked home</small>
            </div>
          </div>

          <div class="steppers-group">
            <div class="stepper-row">
              <label>Bedrooms</label>
              <div class="stepper" data-id="bedrooms" data-min="1" data-max="10" data-val="3">
                <button class="stp-btn stp-minus" type="button" aria-label="Decrease">−</button>
                <span class="stp-val">3</span>
                <button class="stp-btn stp-plus" type="button" aria-label="Increase">+</button>
              </div>
            </div>
            <div class="stepper-row">
              <label>Bathrooms</label>
              <div class="stepper" data-id="bathrooms" data-min="1" data-max="6" data-val="2">
                <button class="stp-btn stp-minus" type="button" aria-label="Decrease">−</button>
                <span class="stp-val">2</span>
                <button class="stp-btn stp-plus" type="button" aria-label="Increase">+</button>
              </div>
            </div>
            <div class="stepper-row">
              <label>Floors</label>
              <div class="stepper" data-id="floors" data-min="1" data-max="4" data-val="1">
                <button class="stp-btn stp-minus" type="button" aria-label="Decrease">−</button>
                <span class="stp-val">1</span>
                <button class="stp-btn stp-plus" type="button" aria-label="Increase">+</button>
              </div>
            </div>
          </div>

          <div class="calc-nav">
            <div></div>
            <button class="btn-calc-next" type="button" data-next="2">Next →</button>
          </div>
        </div>

        <!-- ── STEP 2: APPLIANCES ── -->
        <div class="calc-step hidden" id="step-2">
          <h3 class="calc-step-title">Your Appliances</h3>

          <p class="calc-category-label">Cooling</p>
          <div class="steppers-group">
            <div class="stepper-row">
              <div class="stepper-label-group">
                <label>Air conditioners</label>
                <small>1.5 ton split AC, 1500W each</small>
              </div>
              <div class="stepper" data-id="ac" data-min="0" data-max="8" data-val="2">
                <button class="stp-btn stp-minus" type="button">−</button>
                <span class="stp-val">2</span>
                <button class="stp-btn stp-plus" type="button">+</button>
              </div>
            </div>
            <div class="stepper-row">
              <div class="stepper-label-group">
                <label>Ceiling fans</label>
                <small>75W each</small>
              </div>
              <div class="stepper" data-id="fans" data-min="0" data-max="12" data-val="4">
                <button class="stp-btn stp-minus" type="button">−</button>
                <span class="stp-val">4</span>
                <button class="stp-btn stp-plus" type="button">+</button>
              </div>
            </div>
          </div>

          <p class="calc-category-label">Entertainment</p>
          <div class="steppers-group">
            <div class="stepper-row">
              <div class="stepper-label-group">
                <label>Televisions</label>
                <small>LED, 120W each</small>
              </div>
              <div class="stepper" data-id="tvs" data-min="0" data-max="6" data-val="2">
                <button class="stp-btn stp-minus" type="button">−</button>
                <span class="stp-val">2</span>
                <button class="stp-btn stp-plus" type="button">+</button>
              </div>
            </div>
          </div>

          <p class="calc-category-label">Kitchen</p>
          <div class="steppers-group">
            <div class="stepper-row">
              <div class="stepper-label-group">
                <label>Refrigerator</label>
                <small>200W, runs 30% of time</small>
              </div>
              <div class="stepper" data-id="fridge" data-min="0" data-max="3" data-val="1">
                <button class="stp-btn stp-minus" type="button">−</button>
                <span class="stp-val">1</span>
                <button class="stp-btn stp-plus" type="button">+</button>
              </div>
            </div>
            <div class="stepper-row">
              <div class="stepper-label-group">
                <label>Microwave / OTG</label>
                <small>1200W, ~1 hr/day</small>
              </div>
              <div class="stepper" data-id="microwave" data-min="0" data-max="2" data-val="1">
                <button class="stp-btn stp-minus" type="button">−</button>
                <span class="stp-val">1</span>
                <button class="stp-btn stp-plus" type="button">+</button>
              </div>
            </div>
            <div class="stepper-row">
              <div class="stepper-label-group">
                <label>Washing machine</label>
                <small>500W, ~1 hr/day</small>
              </div>
              <div class="stepper" data-id="washing" data-min="0" data-max="2" data-val="1">
                <button class="stp-btn stp-minus" type="button">−</button>
                <span class="stp-val">1</span>
                <button class="stp-btn stp-plus" type="button">+</button>
              </div>
            </div>
          </div>

          <p class="calc-category-label">Other</p>
          <div class="toggles-group">
            <div class="toggle-row">
              <div class="stepper-label-group">
                <label>Water heater / geyser</label>
                <small>2000W, ~1 hr/day</small>
              </div>
              <label class="toggle-switch">
                <input type="checkbox" id="toggle-geyser" checked />
                <span class="toggle-pill"></span>
              </label>
            </div>
            <div class="toggle-row">
              <div class="stepper-label-group">
                <label>Water pump / motor</label>
                <small>750W, ~2 hrs/day</small>
              </div>
              <label class="toggle-switch">
                <input type="checkbox" id="toggle-pump" />
                <span class="toggle-pill"></span>
              </label>
            </div>
          </div>

          <!-- EV Section -->
          <div class="ev-section">
            <div class="toggle-row ev-toggle-row">
              <label class="ev-main-label">⚡ I have an electric vehicle</label>
              <label class="toggle-switch">
                <input type="checkbox" id="toggle-ev" />
                <span class="toggle-pill"></span>
              </label>
            </div>

            <div class="ev-panel hidden" id="ev-panel">
              <div class="steppers-group">
                <div class="stepper-row">
                  <label>Number of EVs</label>
                  <div class="stepper" data-id="ev-count" data-min="1" data-max="4" data-val="1">
                    <button class="stp-btn stp-minus" type="button">−</button>
                    <span class="stp-val">1</span>
                    <button class="stp-btn stp-plus" type="button">+</button>
                  </div>
                </div>
              </div>

              <p class="calc-field-label" style="margin-top:20px;">Charger type</p>
              <div class="charger-grid" id="charger-grid">
                <div class="charger-card" data-kw="2.3">
                  <strong>2.3 kW</strong>
                  <span>Regular 5A socket</span>
                  <small>Overnight standard plug</small>
                </div>
                <div class="charger-card selected" data-kw="3.3">
                  <strong>3.3 kW</strong>
                  <span>Slow wall box</span>
                  <small>Standard home charger</small>
                </div>
                <div class="charger-card" data-kw="7.4">
                  <strong>7.4 kW</strong>
                  <span>Fast wall box</span>
                  <small>Dedicated AC charger</small>
                </div>
                <div class="charger-card" data-kw="11">
                  <strong>11 kW</strong>
                  <span>Rapid AC charger</span>
                  <small>3-phase, premium setup</small>
                </div>
              </div>

              <div class="sliders-group">
                <div class="slider-row">
                  <label>Daily charging duration: <strong id="ev-hours-val">4</strong> hrs</label>
                  <input type="range" id="ev-hours" min="1" max="12" value="4" step="1" class="calc-slider" />
                </div>
                <div class="slider-row">
                  <label>Days charged per week: <strong id="ev-days-val">5</strong> days</label>
                  <input type="range" id="ev-days" min="1" max="7" value="5" step="1" class="calc-slider" />
                </div>
              </div>

              <div class="ev-impact-panel" id="ev-impact">
                <div class="ev-impact-row">
                  <div>
                    <p class="ev-impact-label">Added daily load (avg)</p>
                    <p class="ev-impact-val" id="ev-added-load">— kWh</p>
                  </div>
                  <div>
                    <p class="ev-impact-label">Extra panels needed</p>
                    <p class="ev-impact-val" id="ev-extra-panels">— panels</p>
                  </div>
                </div>
                <p class="ev-impact-note" id="ev-impact-note"></p>
              </div>
            </div>
          </div>

          <div class="calc-nav">
            <button class="btn-calc-back" type="button" data-back="1">← Back</button>
            <button class="btn-calc-next" type="button" data-next="3">Next →</button>
          </div>
        </div>

        <!-- ── STEP 3: USAGE PATTERN ── -->
        <div class="calc-step hidden" id="step-3">
          <h3 class="calc-step-title">Your Usage Pattern</h3>

          <div class="sliders-group">
            <div class="slider-row">
              <label>AC usage per day: <strong id="ac-hours-val">8</strong> hrs</label>
              <input type="range" id="ac-hours" min="2" max="16" value="8" step="1" class="calc-slider" />
              <div class="slider-range-labels"><span>2 hrs</span><span>16 hrs</span></div>
            </div>
          </div>

          <p class="calc-field-label" style="margin-top:28px;">Daytime occupancy</p>
          <div class="occupancy-grid" id="occupancy-grid">
            <div class="occ-card selected" data-occ="home">
              <strong>🏠 Home all day</strong>
              <small>Housewife, work from home</small>
            </div>
            <div class="occ-card" data-occ="away">
              <strong>🚗 Away daytime</strong>
              <small>Office goers, school hours</small>
            </div>
          </div>

          <div class="sliders-group" style="margin-top:28px;">
            <div class="slider-row">
              <label>Monthly KSEB bill: <strong id="bill-val">₹5,000</strong></label>
              <input type="range" id="bill-slider" min="1000" max="15000" value="5000" step="500" class="calc-slider" />
              <div class="slider-range-labels"><span>₹1,000</span><span>₹15,000</span></div>
            </div>
          </div>

          <div class="calc-nav">
            <button class="btn-calc-back" type="button" data-back="2">← Back</button>
            <button class="btn-calc-next btn-calc-primary" type="button" data-next="4">Calculate →</button>
          </div>
        </div>

        <!-- ── STEP 4: RESULTS ── -->
        <div class="calc-step hidden" id="step-4">
          <h3 class="calc-step-title">Your Personalised Recommendation</h3>

          <!-- Hero result card -->
          <div class="result-hero">
            <p class="result-hero-label">Recommended system size</p>
            <p class="result-hero-kw" id="result-kw">— kW</p>
            <p class="result-hero-units" id="result-units">Generates ~— units/year</p>
          </div>

          <!-- 4 stat cards -->
          <div class="result-stats-grid">
            <div class="result-stat">
              <p class="rs-label">Est. daily consumption</p>
              <p class="rs-val" id="result-daily">—</p>
            </div>
            <div class="result-stat">
              <p class="rs-label">Panels needed</p>
              <p class="rs-val" id="result-panels">—</p>
            </div>
            <div class="result-stat">
              <p class="rs-label">Roof space needed</p>
              <p class="rs-val" id="result-roof">—</p>
            </div>
            <div class="result-stat">
              <p class="rs-label">Subsidy available</p>
              <p class="rs-val" id="result-subsidy">₹78,000</p>
            </div>
          </div>

          <!-- Panel options -->
          <div class="panel-options-section">
            <div class="panel-options-header">
              <p class="calc-field-label" style="margin-bottom:0;">Panel options — Kerala market prices</p>
              <p class="panel-select-hint">Tap a panel to see updated numbers</p>
            </div>

            <!-- A: N-Type TopCon 620W — Premium -->
            <div class="panel-option" id="panel-620" data-panel-id="620">
              <div class="panel-option__header">
                <div>
                  <span class="panel-badge purple">Premium</span>
                  <h4>N-Type TopCon 620W</h4>
                </div>
                <button class="panel-expand" type="button" data-target="panel-620-detail">Learn more ▾</button>
              </div>
              <div class="panel-option__stats">
                <span id="p620-panels">— panels</span>
                <span>22.8% efficiency</span>
                <span id="p620-roof">— sq ft</span>
                <span>₹26/W &nbsp;·&nbsp; <strong id="p620-cost">—</strong></span>
                <span>30yr warranty</span>
              </div>
              <div class="panel-option__detail hidden" id="panel-620-detail">
                <p>The latest N-Type TopCon technology delivers the highest watt-peak and lowest degradation rate on the market. Fewer panels needed, maximum roof-space efficiency. Best choice when you want the most power from the least area.</p>
              </div>
            </div>

            <!-- B: N-Type TopCon 600W — Recommended (default selected) -->
            <div class="panel-option selected" id="panel-600" data-panel-id="600">
              <div class="panel-option__header">
                <div>
                  <span class="panel-badge blue">Recommended</span>
                  <h4>N-Type TopCon 600W</h4>
                </div>
                <button class="panel-expand" type="button" data-target="panel-600-detail">Learn more ▾</button>
              </div>
              <div class="panel-option__stats">
                <span id="p600-panels">— panels</span>
                <span>22.2% efficiency</span>
                <span id="p600-roof">— sq ft</span>
                <span>₹25.7/W &nbsp;·&nbsp; <strong id="p600-cost">—</strong></span>
                <span>30yr warranty</span>
              </div>
              <div class="panel-option__detail hidden" id="panel-600-detail">
                <p>The best all-round choice for Kerala rooftops. N-Type TopCon cells offer superior performance in high-temperature and low-light (overcast monsoon) conditions — exactly what the Kerala climate demands. Excellent long-term value.</p>
              </div>
            </div>

            <!-- C: N-Type TopCon 580W — Best Value -->
            <div class="panel-option" id="panel-580tc" data-panel-id="580tc">
              <div class="panel-option__header">
                <div>
                  <span class="panel-badge green">Best Value</span>
                  <h4>N-Type TopCon 580W</h4>
                </div>
                <button class="panel-expand" type="button" data-target="panel-580tc-detail">Learn more ▾</button>
              </div>
              <div class="panel-option__stats">
                <span id="p580tc-panels">— panels</span>
                <span>21.8% efficiency</span>
                <span id="p580tc-roof">— sq ft</span>
                <span>₹24.5/W &nbsp;·&nbsp; <strong id="p580tc-cost">—</strong></span>
                <span>30yr warranty</span>
              </div>
              <div class="panel-option__detail hidden" id="panel-580tc-detail">
                <p>N-Type TopCon at a more accessible price point. Retains all the key advantages of TopCon technology — low temperature coefficient, excellent low-light performance, and higher energy yield per Wp — at a lower upfront cost than the 600W or 620W variants.</p>
              </div>
            </div>

            <!-- D: Bi-Facial Dual Glass 580W — Bifacial -->
            <div class="panel-option" id="panel-580bf" data-panel-id="580bf">
              <div class="panel-option__header">
                <div>
                  <span class="panel-badge teal">Bifacial</span>
                  <h4>Bifacial Dual Glass 580W</h4>
                </div>
                <button class="panel-expand" type="button" data-target="panel-580bf-detail">Learn more ▾</button>
              </div>
              <div class="panel-option__stats">
                <span id="p580bf-panels">— panels</span>
                <span>21.3% + bifacial gain</span>
                <span id="p580bf-roof">— sq ft</span>
                <span>₹24/W &nbsp;·&nbsp; <strong id="p580bf-cost">—</strong></span>
                <span>30yr warranty</span>
              </div>
              <div class="panel-option__detail hidden" id="panel-580bf-detail">
                <p>Dual-glass bifacial panels generate electricity from both sides, harvesting reflected light from the roof surface and surroundings. Particularly effective on light-coloured flat rooftops. The glass-glass construction also offers better protection against Kerala's heavy monsoon humidity and extreme rainfall.</p>
              </div>
            </div>

            <!-- E: Mono PERC 540W — Economy -->
            <div class="panel-option" id="panel-540" data-panel-id="540">
              <div class="panel-option__header">
                <div>
                  <span class="panel-badge grey">Economy</span>
                  <h4>Mono PERC 540W</h4>
                </div>
                <button class="panel-expand" type="button" data-target="panel-540-detail">Learn more ▾</button>
              </div>
              <div class="panel-option__stats">
                <span id="p540-panels">— panels</span>
                <span>20.5% efficiency</span>
                <span id="p540-roof">— sq ft</span>
                <span>₹23.5/W &nbsp;·&nbsp; <strong id="p540-cost">—</strong></span>
                <span>25yr warranty</span>
              </div>
              <div class="panel-option__detail hidden" id="panel-540-detail">
                <p>Proven Mono PERC technology at the most affordable price point. A solid and reliable choice for homeowners prioritising the lowest upfront cost. Widely available with a strong installer support network across Kerala. Best suited for rooftops with ample available area.</p>
              </div>
            </div>

          </div>

          <!-- Financial snapshot -->
          <div class="fin-snapshot">
            <p class="calc-field-label">Financial snapshot</p>
            <div class="fin-row"><span>Est. annual savings</span><span id="fin-annual">—</span></div>
            <div class="fin-row"><span>Payback period</span><span id="fin-payback">—</span></div>
            <div class="fin-row fin-highlight"><span>25-year savings</span><span id="fin-lifetime">—</span></div>
            <div class="fin-row"><span>CO₂ avoided (25yr)</span><span id="fin-co2">—</span></div>
          </div>

          <!-- Result CTAs -->
          <div class="result-ctas">
            <a href={`${base}/contact`} class="btn btn-primary">Get a personalised quote →</a>
            <button class="btn-calc-outline" type="button" id="recalculate-btn">← Recalculate</button>
          </div>
        </div>

      </div><!-- .calc-card -->
    </div>
  </section>

  <!-- ===== REASSURANCE STRIP ===== -->
  <section class="reassurance-section">
    <div class="container reassurance__inner">
      <div class="reassurance-card">
        <span class="reassurance-icon">🔒</span>
        <h3>Your data stays private</h3>
        <p>We don't store your inputs. This tool runs entirely in your browser.</p>
      </div>
      <div class="reassurance-card">
        <span class="reassurance-icon">✅</span>
        <h3>MNRE-approved installer</h3>
        <p>Every system we install qualifies for the full PM Surya Ghar subsidy.</p>
      </div>
      <div class="reassurance-card">
