  gap: 12px;
}
.fin-row span:first-child { color: var(--color-text-muted); }
.fin-row span:last-child { font-weight: 600; color: var(--color-navy); }
.fin-row.fin-highlight span:last-child {
  font-family: 'Oswald', var(--font-heading);
  font-size: 1.2rem;
  color: var(--calc-blue);
}

/* ── RESULT CTAs ── */
.result-ctas {
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-top: 8px;
}
.result-ctas .btn { justify-content: center; }
.btn-calc-outline {
  background: transparent;
  color: var(--calc-blue);
  border: 2px solid var(--calc-blue);
  border-radius: 50px;
  padding: 12px 32px;
  font-family: var(--font-body);
  font-weight: 500;
  font-size: 0.95rem;
  cursor: pointer;
  transition: all var(--transition);
  text-align: center;
}
.btn-calc-outline:hover { background: var(--calc-blue); color: #fff; }

/* ── REASSURANCE STRIP ── */
.reassurance-section { padding: var(--section-padding); background: #fff; }
.reassurance__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px;
}
.reassurance-card {
  background: var(--color-light);
  border-radius: var(--radius-md);
  padding: 28px 24px;
  border: 1px solid var(--color-border);
  transition: box-shadow var(--transition);
}
.reassurance-card:hover { box-shadow: var(--shadow-md); }
.reassurance-icon { font-size: 2rem; display: block; margin-bottom: 12px; }
.reassurance-card h3 {
  font-family: var(--font-heading);
  font-size: 1rem;
  font-weight: 600;
  color: var(--color-navy);
  margin-bottom: 6px;
}
.reassurance-card p { font-size: 0.88rem; color: var(--color-text-muted); line-height: 1.7; margin: 0; }

/* ── CTA BANNER ── */
.cta-banner { padding: 64px 0; background: var(--color-navy); }
.cta-banner__inner {
  display: grid;
  grid-template-columns: 1fr;
  gap: 28px;
  align-items: center;
}
.cta-banner__content h2 {
  font-family: var(--font-heading);
  font-size: clamp(1.4rem, 3vw, 2rem);
  font-weight: 500;
  color: #fff;
  margin-bottom: 10px;
  line-height: 1.3;
}
.cta-banner__content p {
  color: rgba(255,255,255,0.72);
  font-size: 0.95rem;
  line-height: 1.8;
}
.cta-banner__actions { display: flex; gap: 14px; flex-wrap: wrap; }

/* =============================================
   RESPONSIVE — Tablet & Desktop
   ============================================= */
@media (min-width: 640px) {
  .result-ctas { flex-direction: row; }
  .result-ctas .btn, .result-ctas .btn-calc-outline { flex: 1; }
  .reassurance__inner { grid-template-columns: repeat(3, 1fr); }
}

@media (min-width: 768px) {
  .calc-intro__inner { grid-template-columns: 1fr 1fr; gap: 64px; }
  .calc-intro__image img { max-height: 520px; }
  .how-cards { gap: 14px; }
  .trust-inner { gap: 0; justify-content: space-evenly; }
  .result-stats-grid { grid-template-columns: 1fr 1fr; }
  .occupancy-grid { grid-template-columns: 1fr 1fr; }
}

@media (min-width: 900px) {
  .cta-banner__inner { grid-template-columns: 1fr auto; gap: 48px; }
  .calc-card { padding: 48px 56px 56px; }
}
</style>

<script>
const state = {
  homeType:    'house',
  bedrooms:    3,
  bathrooms:   2,
  floors:      1,
  ac:          2,
  fans:        4,
  tvs:         2,
  fridge:      1,
  microwave:   1,
  washing:     1,
  geyser:      true,
  pump:        false,
  hasEV:       false,
  evCount:     1,
  chargerKw:   3.3,
  chargeHours: 4,
  chargeDays:  5,
  acHours:     8,
  homeAllDay:  true,
  monthlyBill: 5000,
};

const STEP_LABELS = [
  '',
  'Step 1 of 4 — Your home',
  'Step 2 of 4 — Your appliances',
  'Step 3 of 4 — Usage pattern',
  'Step 4 of 4 — Your results',
];

// ── Navigation ──────────────────────────────
function goToStep(n: number) {
  document.querySelectorAll('.calc-step').forEach(el => el.classList.add('hidden'));
  const target = document.getElementById(`step-${n}`);
  target?.classList.remove('hidden');

  document.querySelectorAll<HTMLElement>('.cpb-dot').forEach((dot, i) => {
    const s = i + 1;
    dot.classList.toggle('active', s === n);
    dot.classList.toggle('done',   s < n);
  });
  document.querySelectorAll<HTMLElement>('.cpb-line').forEach((line, i) => {
    line.classList.toggle('done', i + 1 < n);
  });

  const lbl = document.getElementById('step-label');
  if (lbl) lbl.textContent = STEP_LABELS[n] ?? '';

  document.getElementById('calculator')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
  if (n === 4) calculateResults();
}

// ── Stepper controls ─────────────────────────
function initSteppers() {
  document.querySelectorAll<HTMLElement>('.stepper').forEach(stp => {
    const id  = stp.dataset.id ?? '';
    const min = parseInt(stp.dataset.min ?? '0');
    const max = parseInt(stp.dataset.max ?? '99');
    const valEl = stp.querySelector<HTMLElement>('.stp-val');

    stp.querySelector('.stp-minus')?.addEventListener('click', () => {
      let v = parseInt(stp.dataset.val ?? '0');
      if (v > min) { v--; stp.dataset.val = String(v); if (valEl) valEl.textContent = String(v); syncState(id, v); }
    });
    stp.querySelector('.stp-plus')?.addEventListener('click', () => {
      let v = parseInt(stp.dataset.val ?? '0');
      if (v < max) { v++; stp.dataset.val = String(v); if (valEl) valEl.textContent = String(v); syncState(id, v); }
    });
  });
}

const STEPPER_MAP: Record<string, keyof typeof state> = {
  bedrooms: 'bedrooms', bathrooms: 'bathrooms', floors: 'floors',
  ac: 'ac', fans: 'fans', tvs: 'tvs',
  fridge: 'fridge', microwave: 'microwave', washing: 'washing',
  'ev-count': 'evCount',
};
function syncState(id: string, val: number) {
  const key = STEPPER_MAP[id];
  if (key) (state as Record<string, unknown>)[key] = val;
  if (['ev-count'].includes(id)) updateEVImpact();
}

// ── Card selectors ────────────────────────────
function initCards(gridId: string, attr: string, cb: (val: string) => void) {
  document.querySelectorAll<HTMLElement>(`#${gridId} [data-${attr}]`).forEach(card => {
    card.addEventListener('click', () => {
      document.querySelectorAll(`#${gridId} [data-${attr}]`).forEach(c => c.classList.remove('selected'));
      card.classList.add('selected');
      cb(card.dataset[attr] ?? '');
    });
  });
}

// ── Toggles ──────────────────────────────────
function initToggles() {
  document.getElementById('toggle-geyser')?.addEventListener('change', (e) => {
    state.geyser = (e.target as HTMLInputElement).checked;
  });
  document.getElementById('toggle-pump')?.addEventListener('change', (e) => {
    state.pump = (e.target as HTMLInputElement).checked;
  });
  document.getElementById('toggle-ev')?.addEventListener('change', (e) => {
    state.hasEV = (e.target as HTMLInputElement).checked;
    document.getElementById('ev-panel')?.classList.toggle('hidden', !state.hasEV);
    if (state.hasEV) updateEVImpact();
  });
}

// ── Sliders ──────────────────────────────────
function bindSlider(id: string, displayId: string, fmt: (v: number) => string, cb: (v: number) => void) {
  const input = document.getElementById(id) as HTMLInputElement | null;
  const disp  = document.getElementById(displayId);
  if (!input) return;
  input.addEventListener('input', () => {
    const v = parseInt(input.value);
    if (disp) disp.textContent = fmt(v);
    cb(v);
    // Update gradient fill
    const pct = ((v - +input.min) / (+input.max - +input.min)) * 100;
    input.style.background = `linear-gradient(to right, #185FA5 ${pct}%, #dce5ef ${pct}%)`;
  });
  // Set initial gradient
  const pct = ((+input.value - +input.min) / (+input.max - +input.min)) * 100;
  input.style.background = `linear-gradient(to right, #185FA5 ${pct}%, #dce5ef ${pct}%)`;
}

// ── EV live impact ────────────────────────────
function updateEVImpact() {
  const evDaily = (state.chargerKw * state.chargeHours * state.chargeDays * state.evCount) / 7;
  const extra   = Math.ceil((evDaily / 4.5 * 1.25) * 1000 / 540);
  setText('ev-added-load',   evDaily.toFixed(1) + ' kWh');
  setText('ev-extra-panels', extra + ' panel' + (extra !== 1 ? 's' : ''));
  setText('ev-impact-note',
    `Charging ${state.evCount} EV(s) at ${state.chargerKw} kW for ${state.chargeHours} hrs/day, ` +
    `${state.chargeDays} days/week adds an average of ${evDaily.toFixed(1)} kWh/day to your system requirement.`
  );
}

// ── Module-level cache (populated by calculateResults) ───────
const PANEL_SPECS = [
  { id: '620',   watt: 620, ppw: 26.0,  sqft: 26, label: '620W TopCon' },
  { id: '600',   watt: 600, ppw: 25.7,  sqft: 25, label: '600W TopCon' },
  { id: '580tc', watt: 580, ppw: 24.5,  sqft: 24, label: '580W TopCon' },
  { id: '580bf', watt: 580, ppw: 24.0,  sqft: 25, label: '580W Bifacial' },
  { id: '540',   watt: 540, ppw: 23.5,  sqft: 23, label: '540W PERC' },
];
type PanelResult = typeof PANEL_SPECS[0] & { count: number; roof: number; cost: number };
let cachedPanelResults: PanelResult[] = [];
let cachedSysKw     = 0;
let cachedAnnSave   = 0;
let selectedPanelId = '600';

const inr = (n: number) => isNaN(n) || !isFinite(n) ? '—' : n.toLocaleString('en-IN');

// ── Calculation ──────────────────────────────
function calculateResults() {
  const s = state;

  let daily = 0;
  daily += s.ac        * 1500   * s.acHours / 1000;
  daily += s.fans      * 75     * 10        / 1000;
  daily += s.tvs       * 120    * 6         / 1000;
  daily += s.fridge    * 200    * 24 * 0.3  / 1000;
  daily += s.microwave * 1200   * 1         / 1000;
  daily += s.washing   * 500    * 1         / 1000;
  const rooms = s.bedrooms + s.bathrooms + 1;
  daily += rooms       * 50     * 8         / 1000;
  if (s.geyser) daily += 2000 * 1 / 1000;
  if (s.pump)   daily += 750  * 2 / 1000;

  if (s.hasEV) {
    const evAvg = (s.chargerKw * s.chargeHours * s.chargeDays * s.evCount) / 7;
    daily += isNaN(evAvg) ? 0 : evAvg;
  }

  if (!s.homeAllDay) daily *= 0.7;
  daily = isNaN(daily) ? 0 : daily;

  let sysKw      = Math.ceil(daily / 4.5 * 1.25);
  sysKw          = Math.max(1, isNaN(sysKw) ? 1 : sysKw);
  const annUnits = sysKw * 1200;
  const annSave  = s.monthlyBill * 11;
  const lifetime = annSave * 25;
  const co2      = Math.round(annUnits * 0.82 * 25 / 1000);

  // Cache for panel-switch updates
  cachedSysKw   = sysKw;
  cachedAnnSave = annSave;

  // Compute per-panel data
  cachedPanelResults = PANEL_SPECS.map(p => {
    const count = Math.ceil(sysKw * 1000 / p.watt);
    const roof  = count * p.sqft;
    const cost  = count * p.watt * p.ppw;
    return { ...p, count, roof, cost };
  });

  // Static fields (same regardless of panel choice)
  setText('result-kw',    sysKw + ' kW');
  setText('result-units', 'Generates ~' + inr(annUnits) + ' units/year');
  setText('result-daily', daily.toFixed(1) + ' units/day');
  setText('fin-annual',   '₹' + inr(annSave));
  setText('fin-lifetime', '₹' + inr(lifetime));
  setText('fin-co2',      co2 + ' tonnes');

  // Per-panel card stats (count, roof, cost chips inside each card)
  cachedPanelResults.forEach(p => {
    setText(`p${p.id}-panels`, p.count + ' panels');
    setText(`p${p.id}-roof`,   p.roof  + ' sq ft');
    setText(`p${p.id}-cost`,   '₹' + inr(Math.round(p.cost)));
  });

  // Apply the currently selected panel to headline + financial rows
  updatePanelDisplay(selectedPanelId);
}

// ── Update headline stats & financials for the chosen panel ──
function updatePanelDisplay(id: string) {
  if (!cachedPanelResults.length) return;
  selectedPanelId = id;

  const p = cachedPanelResults.find(r => r.id === id) ?? cachedPanelResults[1]; // fallback 600W
  const bos     = cachedSysKw * 55000;
  const cost    = p.cost + bos;
  const subsidy = Math.min(78000, cost * 0.4);
  const net     = cost - subsidy;
  const payback = net / cachedAnnSave;

  setText('result-panels', p.count + ' panels (' + p.label + ')');
  setText('result-roof',   p.roof  + ' sq ft');
  setText('result-subsidy','₹' + inr(Math.round(subsidy)));
  setText('fin-payback',   isNaN(payback) || !isFinite(payback) ? '—' : payback.toFixed(1) + ' years');

  // Mark selected card
  document.querySelectorAll<HTMLElement>('.panel-option[data-panel-id]').forEach(card => {
    card.classList.toggle('selected', card.dataset.panelId === id);
  });
}

// ── Panel selection click handler ────────────
function initPanelSelect() {
  document.querySelectorAll<HTMLElement>('.panel-option[data-panel-id]').forEach(card => {
    card.addEventListener('click', (e) => {
      // Ignore clicks on the "Learn more" button or expanded detail text
      if ((e.target as HTMLElement).closest('.panel-expand, .panel-option__detail')) return;
      if (!cachedPanelResults.length) return;
      updatePanelDisplay(card.dataset.panelId ?? '600');
    });
  });
}

function setText(id: string, val: string) {
  const el = document.getElementById(id);
  if (el) el.textContent = val;
}

// ── Panel expand ─────────────────────────────
function initPanelExpand() {
  document.querySelectorAll<HTMLElement>('.panel-expand').forEach(btn => {
    btn.addEventListener('click', () => {
      const detail = document.getElementById(btn.dataset.target ?? '');
      if (!detail) return;
      const hidden = detail.classList.toggle('hidden');
      btn.textContent = hidden ? 'Learn more ▾' : 'Close ▲';
    });
  });
}

// ── Recalculate ──────────────────────────────
function resetAll() {
  Object.assign(state, {
    homeType:'house', bedrooms:3, bathrooms:2, floors:1,
    ac:2, fans:4, tvs:2, fridge:1, microwave:1, washing:1,
    geyser:true, pump:false, hasEV:false, evCount:1,
    chargerKw:3.3, chargeHours:4, chargeDays:5,
    acHours:8, homeAllDay:true, monthlyBill:5000,
  });

  // Reset cards
  ['house','apartment','villa','rowhouse'].forEach(t => {
    const c = document.querySelector<HTMLElement>(`.ht-card[data-type="${t}"]`);
    c?.classList.toggle('selected', t === 'house');
  });
  document.querySelectorAll<HTMLElement>('.charger-card').forEach(c => {
    c.classList.toggle('selected', c.dataset.kw === '3.3');
  });
  document.querySelectorAll<HTMLElement>('.occ-card').forEach(c => {
    c.classList.toggle('selected', c.dataset.occ === 'home');
  });

  // Reset steppers
  const defaults: Record<string, number> = {
    bedrooms:3, bathrooms:2, floors:1, ac:2, fans:4,
    tvs:2, fridge:1, microwave:1, washing:1, 'ev-count':1,
  };
  document.querySelectorAll<HTMLElement>('.stepper').forEach(s => {
    const id  = s.dataset.id ?? '';
    const val = defaults[id] ?? parseInt(s.dataset.min ?? '0');
    s.dataset.val = String(val);
    const el = s.querySelector<HTMLElement>('.stp-val');
    if (el) el.textContent = String(val);
  });

  // Reset toggles
  (document.getElementById('toggle-geyser') as HTMLInputElement).checked = true;
  (document.getElementById('toggle-pump')   as HTMLInputElement).checked = false;
  (document.getElementById('toggle-ev')     as HTMLInputElement).checked = false;
  document.getElementById('ev-panel')?.classList.add('hidden');

  // Reset sliders
  const sliders: [string, string, string][] = [
    ['ac-hours', 'ac-hours-val', '8'],
    ['bill-slider', 'bill-val', '₹5,000'],
    ['ev-hours', 'ev-hours-val', '4'],
    ['ev-days', 'ev-days-val', '5'],
  ];
  sliders.forEach(([sid, did, dv]) => {
    const el = document.getElementById(sid) as HTMLInputElement | null;
    if (el) {
      el.value = dv.replace(/[^0-9]/g, '') || dv;
      const pct = ((+el.value - +el.min) / (+el.max - +el.min)) * 100;
      el.style.background = `linear-gradient(to right, #185FA5 ${pct}%, #dce5ef ${pct}%)`;
    }
    setText(did, dv);
  });

  // Reset panel selection to default (600W)
  selectedPanelId = '600';
  cachedPanelResults = [];
  document.querySelectorAll<HTMLElement>('.panel-option[data-panel-id]').forEach(card => {
    card.classList.toggle('selected', card.dataset.panelId === '600');
  });

  // Reset panel expanders
  document.querySelectorAll('.panel-option__detail').forEach(d => d.classList.add('hidden'));
  document.querySelectorAll<HTMLElement>('.panel-expand').forEach(b => { b.textContent = 'Learn more ▾'; });
}

// ── Bootstrap ────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  initSteppers();
  initCards('home-type-grid', 'type', v => { state.homeType = v; });
  initCards('charger-grid',   'kw',   v => { state.chargerKw = parseFloat(v); updateEVImpact(); });
  initCards('occupancy-grid', 'occ',  v => { state.homeAllDay = v === 'home'; });
  initToggles();
  initPanelExpand();
  initPanelSelect();

  bindSlider('ac-hours',   'ac-hours-val',  v => String(v), v => { state.acHours = v; });
  bindSlider('bill-slider','bill-val', v => '₹' + v.toLocaleString('en-IN'), v => { state.monthlyBill = v; });
  bindSlider('ev-hours',   'ev-hours-val',  v => String(v), v => { state.chargeHours = v; updateEVImpact(); });
  bindSlider('ev-days',    'ev-days-val',   v => String(v), v => { state.chargeDays  = v; updateEVImpact(); });

  document.querySelectorAll<HTMLElement>('.btn-calc-next').forEach(btn => {
    btn.addEventListener('click', () => goToStep(parseInt(btn.dataset.next ?? '1')));
  });
  document.querySelectorAll<HTMLElement>('.btn-calc-back').forEach(btn => {
    btn.addEventListener('click', () => goToStep(parseInt(btn.dataset.back ?? '1')));
  });

  document.getElementById('recalculate-btn')?.addEventListener('click', () => {
    resetAll();
    goToStep(1);
  });

  document.querySelector<HTMLAnchorElement>('.hero-scroll-btn')?.addEventListener('click', e => {
    e.preventDefault();
    document.getElementById('calculator')?.scrollIntoView({ behavior: 'smooth' });
  });
});
</script>
