---
import '../styles/global.css';
import ChatWidget from '../components/ChatWidget.astro';

const { title = 'Rayenna Energy — Solar Solutions in Kochi', description = 'Rayenna Energy is a leading provider of innovative solar energy solutions in Kochi, Kerala. Switch to solar and save on energy costs while reducing your carbon footprint.' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const navLinks = [
  { href: `${base}/`, label: 'Home' },
  { href: `${base}/about`, label: 'About us' },
  { href: `${base}/services`, label: 'Our Services' },
  { href: `${base}/solar-calculator`, label: 'Solar Calculator', special: true },
  { href: `${base}/media`, label: 'Media' },
  { href: `${base}/blog`, label: 'Blog' },
  { href: `${base}/faqs`, label: 'FAQs' },
  { href: `${base}/contact`, label: 'Contact us' },
];
const currentPath = Astro.url.pathname;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title}</title>
  <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Oswald:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body>

  <!-- ===== NAVBAR ===== -->
  <header class={`navbar${currentPath === `${base}/` || currentPath === `${base}` ? ' navbar--hero' : ''}`} id="navbar">
    <div class="navbar__inner">
      <a href={`${base}/`} class="navbar__logo" aria-label="Rayenna Energy Home">
        <img src={`${base}/media/rayenna-logo-nav.png`} alt="Rayenna Energy" class="logo-img" />
      </a>

      <nav class="navbar__nav" id="main-nav" aria-label="Main navigation">
        {navLinks.map(link => (
          <a
            href={link.href}
            class={`nav-link ${link.special ? 'nav-calculator-link' : ''} ${currentPath === link.href || (link.href !== `${base}/` && currentPath.startsWith(link.href)) ? 'active' : ''}`}
          >{link.special ? '☀️ ' : ''}{link.label}</a>
        ))}
      </nav>

      <button class="navbar__burger" id="burger" aria-label="Toggle menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>

    <!-- Mobile menu -->
    <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
      {navLinks.map(link => (
        link.special
          ? <a href={link.href} class="mobile-link mobile-nav-calculator">☀️ Calculate My Savings</a>
          : <a href={link.href} class="mobile-link">{link.label}</a>
      ))}
    </div>
  </header>

  <!-- ===== MAIN ===== -->
  <main>
    <slot />
  </main>

  <!-- ===== FOOTER ===== -->
  <footer class="footer">
    <div class="container footer__grid">

      <!-- Col 1: Logo -->
      <div class="footer__col footer__col--logo">
        <img src={`${base}/media/Logo-white.webp`} alt="Rayenna Energy" class="footer-logo-img" />
      </div>

      <!-- Col 2: MNRE Badge -->
      <div class="footer__col footer__col--badge">
        <img src={`${base}/media/Artboard-2-copymnre.webp`} alt="MNRE Approved Channel Partner — Govt of India" class="footer-badge-img" />
      </div>

      <!-- Col 3: About Us -->
      <div class="footer__col footer__col--about">
        <h4 class="footer__heading">About Us</h4>
        <p class="footer__text">Rayenna Energy is a leading provider of innovative solar energy solutions dedicated to transforming the way you harness and use energy. With a deep commitment to delivering high-quality solar installations that prioritise sustainability, efficiency, and affordability, we believe in creating a greener future.</p>
      </div>

      <!-- Col 4: Contact -->
      <div class="footer__col footer__col--contact">
        <h4 class="footer__heading">Contact us</h4>
        <p class="footer__text">No. 3329/52, Ray Bhavan, Nh Bypass,<br />Thykoodam, Vyttila,<br />Ernakulam, Kerala, India, 682019</p>
        <p class="footer__text" style="margin-top:8px;">
          <a href="tel:+917907369304" class="footer__link">+91 7907 369 304</a><br />
          <a href="mailto:sales@rayenna.energy" class="footer__link">sales@rayenna.energy</a><br />
          <a href="https://rayennaenergy.com" class="footer__link">rayennaenergy.com</a>
        </p>
        <div class="footer__social">
          <a href="https://www.facebook.com/profile.php?id=61565224468823" target="_blank" rel="noopener" aria-label="Facebook" class="social-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
          </a>
          <a href="https://www.instagram.com/rayenna_energy/" target="_blank" rel="noopener" aria-label="Instagram" class="social-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
          </a>
          <a href="https://www.linkedin.com/company/rayenna-energy/" target="_blank" rel="noopener" aria-label="LinkedIn" class="social-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z"/><circle cx="4" cy="4" r="2"/></svg>
          </a>
        </div>
      </div>

    </div>

    <div class="footer__bottom">
      <div class="container footer__bottom-inner">
        <p>© 2025 Rayenna Energy, All Rights Reserved.</p>
      </div>
    </div>
  </footer>

  <!-- Ray AI Chat Widget -->
  <ChatWidget />

  <!-- WhatsApp Floating Button -->
  <a
    href="https://wa.me/917907369304"
    target="_blank"
    rel="noopener noreferrer"
    class="wa-float"
    aria-label="Chat with us on WhatsApp"
  >
    <svg viewBox="0 0 32 32" xmlns="http://www.w3.org/2000/svg"
         fill="white" width="26" height="26" aria-hidden="true">
      <path d="M16 .5C7.439.5.5 7.439.5 16c0 2.75.703 5.389 2.043 7.719L.5 31.5l8-2
               c2.219 1.188 4.719 1.813 7.5 1.813C24.561 31.313 31.5 24.374 31.5
               15.813 31.5 7.439 24.561.5 16 .5zm0 28.625c-2.5 0-4.938-.656-7.063-1.906
               l-.5-.313-5.25 1.313 1.375-5.063-.344-.531C2.844 20.5 2.125 18.281
               2.125 16 2.125 8.344 8.344 2.125 16 2.125S29.875 8.344 29.875 16
               23.656 29.125 16 29.125zm7.813-9.969c-.438-.219-2.563-1.25-2.969-1.406
               s-.688-.219-.969.219-1.125 1.406-1.375 1.688-.5.313-.938.094
               c-.438-.219-1.844-.688-3.5-2.188-1.313-1.156-2.188-2.594-2.438-3.031
               s-.031-.688.188-.906c.188-.188.438-.5.656-.75s.281-.438.438-.719
               .156-.531.063-.75-1-2.375-1.375-3.25c-.375-.875-.75-.75-1-.75
               s-.531 0-.813 0-1.063.281-1.625.875S7.5 10.719 7.5 12.5c0 1.781
               1.313 3.531 1.5 3.781s2.594 3.969 6.281 5.563c.875.375 1.563.594
               2.094.781.875.281 1.688.25 2.313.156.719-.094 2.219-.906 2.531-1.781
               s.313-1.625.219-1.781-.344-.281-.781-.5z"/>
    </svg>
    <span class="wa-tooltip" aria-hidden="true">Chat with us!</span>
  </a>

  <style>
    /* ── MOBILE FIRST (base styles) ── */
    .wa-float {
      position: fixed;
      bottom: 24px;
      right: 20px;
      width: 52px;
      height: 52px;
      min-width: 48px;
      min-height: 48px;
      background-color: #25D366;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      box-shadow: 0 3px 10px rgba(37, 211, 102, 0.45);
      z-index: 9999;
      text-decoration: none;
      -webkit-tap-highlight-color: transparent;
      animation: wa-pulse-mobile 2.5s infinite;
      transition: transform 0.2s ease;
    }

    .wa-tooltip {
      display: none;
    }

    @keyframes wa-pulse-mobile {
      0%   { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.45); }
      70%  { box-shadow: 0 0 0 10px rgba(37, 211, 102, 0); }
      100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
    }

    /* ── TABLET & DESKTOP (min-width: 768px) ── */
    @media (min-width: 768px) {
      .wa-float {
        bottom: 30px;
        right: 30px;
        width: 58px;
        height: 58px;
        animation: wa-pulse-desktop 2s infinite;
      }

      .wa-float:hover {
        transform: scale(1.1);
        animation: none;
        box-shadow: 0 6px 20px rgba(37, 211, 102, 0.6);
      }

      .wa-tooltip {
        display: block;
        position: absolute;
        right: 68px;
        background: #1a1a1a;
        color: #fff;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        font-family: sans-serif;
        white-space: nowrap;
        opacity: 0;
        pointer-events: none;
        transition: opacity 0.2s ease;
      }

      .wa-tooltip::after {
        content: '';
        position: absolute;
        left: 100%;
        top: 50%;
        transform: translateY(-50%);
        border: 6px solid transparent;
        border-left-color: #1a1a1a;
      }

      .wa-float:hover .wa-tooltip {
        opacity: 1;
      }

      @keyframes wa-pulse-desktop {
        0%   { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0.5); }
        70%  { box-shadow: 0 0 0 14px rgba(37, 211, 102, 0); }
        100% { box-shadow: 0 0 0 0 rgba(37, 211, 102, 0); }
      }
    }
  </style>
  <!-- End WhatsApp Floating Button -->

</body>
</html>

<style>
/* ===== NAVBAR ===== */
.navbar {
  position: fixed;
  top: 0; left: 0; right: 0;
  z-index: 1000;
  background: var(--color-white);
  box-shadow: var(--shadow-sm);
  transition: background 0.4s ease, box-shadow 0.4s ease;
}
/* Homepage only: start transparent */
.navbar--hero {
  background: transparent;
  box-shadow: none;
}
.navbar--hero.navbar--scrolled,
.navbar--scrolled {
  background: rgba(255,255,255,0.97);
  box-shadow: var(--shadow-md);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.navbar__inner {
  display: flex;
  align-items: center;
  gap: 32px;
  height: 72px;
  width: 100%;
  padding: 0 32px 0 24px;
}
.navbar__logo {
  display: flex;
  align-items: center;
  flex-shrink: 0;
  padding: 4px 0;
}
.logo-img {
  height: 34px;
  width: auto;
  display: block;
}
.navbar__nav {
  display: flex;
  align-items: center;
  gap: 4px;
  margin-left: auto;
}
.nav-link {
  font-family: var(--font-heading);
  font-weight: 400;
  font-size: 0.9rem;
  color: var(--color-text);
  padding: 8px 14px;
  border-radius: var(--radius-sm);
  transition: all var(--transition);
  letter-spacing: 0.2px;
}
.nav-link:hover, .nav-link.active {
  color: var(--color-primary);
  background: var(--color-primary-light);
}
/* Homepage transparent state: navy text, readable on light hero */
.navbar--hero:not(.navbar--scrolled) .nav-link {
  color: var(--color-navy);
  font-weight: 500;
}
.navbar--hero:not(.navbar--scrolled) .nav-link:hover,
.navbar--hero:not(.navbar--scrolled) .nav-link.active {
  color: var(--color-primary);
  background: rgba(168,56,56,0.1);
}

/* Desktop calculator pill — only visible at 768px+ (where .navbar__nav shows) */
@media (min-width: 768px) {
  .nav-link.nav-calculator-link {
    background-color: var(--color-primary);
    color: #fff;
    padding: 8px 18px;
    border-radius: 20px;
    font-weight: 600;
    transition: opacity 0.2s ease;
  }
  .nav-link.nav-calculator-link:hover,
  .nav-link.nav-calculator-link.active {
    background-color: var(--color-primary-dark);
    color: #fff;
    opacity: 0.92;
  }
  /* Transparent hero override */
  .navbar--hero:not(.navbar--scrolled) .nav-link.nav-calculator-link {
    background-color: var(--color-primary);
    color: #fff;
  }
}

/* Burger */
.navbar__burger {
  display: none;
  flex-direction: column;
  gap: 5px;
  background: none;
  border: none;
  cursor: pointer;
  padding: 8px;
  margin-left: auto;
}
.navbar__burger span {
  display: block;
  width: 24px;
  height: 2px;
  background: var(--color-secondary);
  border-radius: 2px;
  transition: background var(--transition);
}
.navbar--hero:not(.navbar--scrolled) .navbar__burger span {
  background: var(--color-navy);
  transition: all var(--transition);
}
.navbar__burger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
.navbar__burger.open span:nth-child(2) { opacity: 0; }
.navbar__burger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

/* Mobile menu */
.mobile-menu {
  display: none;
  flex-direction: column;
  padding: 16px 24px 24px;
  border-top: 1px solid rgba(255,255,255,0.2);
  gap: 4px;
  background: rgba(255,255,255,0.97);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
}
.mobile-menu.open { display: flex; }
.mobile-link {
  font-family: var(--font-heading);
  font-weight: 600;
  font-size: 0.95rem;
  color: var(--color-secondary);
  padding: 12px 8px;
  border-bottom: 1px solid var(--color-border);
  transition: color var(--transition);
}
.mobile-link:hover { color: var(--color-primary); }
.mobile-nav-calculator {
  display: block;
  width: 100%;
  text-align: center;
  padding: 14px 20px;
  margin-top: 8px;
  background-color: var(--color-primary);
  color: #fff;
  border-radius: 8px;
  font-weight: 600;
  text-decoration: none;
  min-height: 52px;
  line-height: 1.4;
  border-bottom: none;
  -webkit-tap-highlight-color: transparent;
}
.mobile-nav-calculator:hover,
.mobile-nav-calculator:active { background-color: var(--color-primary-dark); color: #fff; }

/* ===== FOOTER ===== */
.footer {
  background: var(--color-navy);
  color: rgba(255,255,255,0.8);
  padding: 52px 0 0;
}
.footer__grid {
  display: grid;
  grid-template-columns: 180px 140px 1fr 1fr;
  gap: 48px;
  align-items: center;
  padding-bottom: 48px;
}

/* Col 1 — Stacked logo */
.footer__col--logo {
  display: flex;
  align-items: center;
  justify-content: flex-start;
}
.footer-logo-img {
  width: 168px;
  height: auto;
  display: block;
  object-fit: contain;
}

/* Col 2 — MNRE badge */
.footer__col--badge {
  display: flex;
  align-items: center;
  justify-content: center;
}
.footer-badge-img {
  width: 144px;
  height: 144px;
  object-fit: contain;
  display: block;
}

/* Col 3 & 4 — text columns */
.footer__col--about,
.footer__col--contact {
  align-self: flex-start;
}
.footer__heading {
  font-family: var(--font-heading);
  font-weight: 500;
  font-size: 0.85rem;
  letter-spacing: 1.5px;
  text-transform: uppercase;
  color: var(--color-white);
  margin-bottom: 16px;
}
.footer__text {
  font-size: 0.88rem;
  line-height: 1.85;
  color: rgba(255,255,255,0.72);
}

/* Social links & inline links */
.footer__link {
  color: rgba(255,255,255,0.72);
  transition: color var(--transition);
}
.footer__link:hover { color: var(--color-primary); }

.footer__social {
  display: flex;
  gap: 10px;
  margin-top: 20px;
  flex-wrap: wrap;
}
.social-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  background: rgba(255,255,255,0.1);
  border-radius: 50%;
  color: rgba(255,255,255,0.75);
  transition: all var(--transition);
  flex-shrink: 0;
}
.social-link:hover {
  background: var(--color-primary);
  color: white;
  transform: translateY(-2px);
}

/* Bottom bar */
.footer__bottom {
  border-top: 1px solid rgba(255,255,255,0.1);
  padding: 18px 0;
}
.footer__bottom-inner {
  display: flex;
  justify-content: center;
  align-items: center;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.45);
}

@media (max-width: 1024px) {
  .footer__grid { grid-template-columns: 160px 120px 1fr; gap: 32px; }
  .footer__col--contact { grid-column: 2 / span 2; }
}
@media (max-width: 768px) {
  .navbar__nav { display: none; }
  .navbar__burger { display: flex; }
  .footer__grid { grid-template-columns: 1fr 1fr; gap: 32px; align-items: start; }
  .footer__col--logo { grid-column: 1; justify-content: flex-start; }
  .footer__col--badge { grid-column: 2; justify-content: flex-start; }
  .footer__col--about { grid-column: 1; }
  .footer__col--contact { grid-column: 2; }
  .footer__bottom-inner { text-align: center; }
}
@media (max-width: 480px) {
  .footer__grid {
    grid-template-columns: 1fr 1fr;
    gap: 24px 16px;
  }
  /* Logo and badge: side by side in row 1 */
  .footer__col--logo {
    grid-column: 1;
    justify-content: flex-start;
    align-items: flex-start;
  }
  .footer__col--badge {
    grid-column: 2;
    justify-content: flex-start;
    align-items: flex-start;
  }
  /* About and Contact: each spans full width below */
  .footer__col--about,
  .footer__col--contact {
    grid-column: 1 / span 2;
  }
  /* Scale logos down to fit side by side */
  .footer-logo-img { width: 130px; }
  .footer-badge-img { width: 100px; height: 100px; }
}
</style>

<script>
  const navbar = document.getElementById('navbar');
  const updateNav = () => {
    if (navbar) navbar.classList.toggle('navbar--scrolled', window.scrollY > 20);
  };
  window.addEventListener('scroll', updateNav, { passive: true });
  updateNav();

  const burger = document.getElementById('burger');
  const mobileMenu = document.getElementById('mobile-menu');
  burger?.addEventListener('click', () => {
    const open = mobileMenu?.classList.toggle('open');
    burger.classList.toggle('open', open);
    burger.setAttribute('aria-expanded', String(open));
    mobileMenu?.setAttribute('aria-hidden', String(!open));
  });
</script>
